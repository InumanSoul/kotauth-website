---
import '@/styles/global.css';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import { type Locale, defaultLocale, getAlternateLinks, stripLocalePrefix } from '@/i18n';

const BASE_URL = 'https://kotauth.com';
const SITE_NAME = 'Kotauth';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const {
  title: rawTitle = 'Kotauth - Identity Infrastructure for Modern Applications',
  description = 'The self-hosted authentication platform that combines enterprise power with developer experience. OAuth2, OIDC, Multi-Tenancy, MFA. Deploy in under a minute.',
  path = '/',
  ogImage = `${BASE_URL}/og-image.png`,
} = Astro.props;

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const cleanPath = stripLocalePrefix(path);
const alternateLinks = getAlternateLinks(cleanPath);

const title = rawTitle.includes(SITE_NAME) ? rawTitle : `${rawTitle} | ${SITE_NAME}`;
const canonicalUrl = `${BASE_URL}${path}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="authentication, identity management, self-hosted auth, open-source auth, OAuth2, OIDC, SSO, JWT, multi-tenant, MFA, Docker auth" />
    <meta name="author" content="@InumanSoul, Kotauth Team" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@kotauth" />
    <meta name="twitter:creator" content="@InumanSoul" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map(({ locale: l, href }) => (
      <link rel="alternate" hreflang={l} href={`${BASE_URL}${href}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${BASE_URL}${cleanPath}`} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Kotauth",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Linux, Docker",
      "description": "Open-source, self-hosted authentication and identity management platform. OAuth2/OIDC compliant, multi-tenant, Docker-native.",
      "url": "https://kotauth.dev",
      "softwareVersion": "1.19.2",
      "license": "https://opensource.org/licenses/MIT",
      "codeRepository": "https://github.com/InumanSoul/kotauth",
      "programmingLanguage": "Kotlin",
      "author": {
        "@type": "Person",
        "name": "Anderson",
        "url": "https://github.com/InumanSoul"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": [
        "OAuth 2.0 and OpenID Connect",
        "Multi-tenant workspaces",
        "MFA / TOTP support",
        "Magic-link passwordless authentication",
        "Email OTP passwordless authentication",
        "Social login (Google, GitHub)",
        "RBAC with roles and groups",
        "Client default roles",
        "Tenant backup and restore",
        "Admin impersonation",
        "Redis distributed sessions",
        "Internationalization (i18n)",
        "Docker-native deployment",
        "REST API with OpenAPI spec",
        "AI-native management (MCP)",
        "Audit logging and webhooks",
        "Transactional email branding",
        "Security hardening (Tier 1 + Tier 2)"
      ]
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/kotauth-favicon.png" />

    <!-- LLMs -->
    <link rel="llms-txt" href="/llms.txt" />

    <!-- OpenPanel Analytics -->
    <script is:inline>
      window.op=window.op||function(){var n=[];return new Proxy(function(){arguments.length&&n.push([].slice.call(arguments))},{get:function(t,r){return"q"===r?n:function(){n.push([r].concat([].slice.call(arguments)))}} ,has:function(t,r){return"q"===r}}) }();
      window.op('init', {
        apiUrl: 'https://analytics.oriana.com.py/api',
        clientId: '91ca4ad4-f953-46e8-bcc9-c79839599bea',
        trackScreenViews: true,
        trackOutgoingLinks: true,
        trackAttributes: true,
      });
    </script>
    <script src="https://openpanel.dev/op1.js" defer async></script>
  </head>
  <body class="min-h-screen bg-kotauth-bg-primary">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Site-wide interactions: scroll reveal, copy, tabs, themes, contact form -->
    <script is:inline>
      (function () {
        // ── Scroll-reveal observer ──
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                var d = +(e.target.dataset.revealDelay || 0);
                if (d) {
                  setTimeout(function () { e.target.classList.add('revealed'); }, d);
                } else {
                  e.target.classList.add('revealed');
                }
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '-80px 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach(function (el) { io.observe(el); });

        // ── Copy buttons (CodeBlock) ──
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-copy]');
          if (!btn) return;
          var block = btn.closest('[data-code-block]');
          var raw = block.querySelector('textarea').value;
          navigator.clipboard.writeText(raw).then(function () {
            btn.querySelector('[data-copy-icon]').classList.add('hidden');
            btn.querySelector('[data-check-icon]').classList.remove('hidden');
            var label = btn.querySelector('[data-copy-label]');
            label.textContent = 'Copied!';
            label.classList.add('text-kotauth-success');
            setTimeout(function () {
              btn.querySelector('[data-copy-icon]').classList.remove('hidden');
              btn.querySelector('[data-check-icon]').classList.add('hidden');
              label.textContent = 'Copy';
              label.classList.remove('text-kotauth-success');
            }, 2000);
          });
        });

        // ── Tab switching (TabbedCodeBlock) ──
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-tab-btn]');
          if (!btn) return;
          var container = btn.closest('[data-tabbed]');
          var idx = btn.dataset.tabBtn;
          container.querySelectorAll('[data-tab-btn]').forEach(function (b) {
            var active = b.dataset.tabBtn === idx;
            b.classList.toggle('text-kotauth-text-primary', active);
            b.classList.toggle('text-kotauth-text-tertiary', !active);
            b.classList.toggle('hover:text-kotauth-text-secondary', !active);
            var ind = b.querySelector('[data-tab-indicator]');
            if (ind) ind.classList.toggle('hidden', !active);
          });
          container.querySelectorAll('[data-tab-panel]').forEach(function (p) {
            var active = p.dataset.tabPanel === idx;
            p.classList.toggle('hidden', !active);
            if (active) {
              p.classList.remove('crossfade-enter');
              void p.offsetWidth;
              p.classList.add('crossfade-enter');
            }
          });
        });

        // ── Theme switching (AuthShowcase) ──
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-theme-btn]');
          if (!btn) return;
          var showcase = btn.closest('[data-auth-showcase]');
          var theme = btn.dataset.themeBtn;
          showcase.querySelectorAll('[data-theme-btn]').forEach(function (b) {
            var active = b.dataset.themeBtn === theme;
            b.classList.toggle('bg-kotauth-primary', active);
            b.classList.toggle('text-white', active);
            b.classList.toggle('text-kotauth-text-muted', !active);
            b.classList.toggle('hover:text-kotauth-text-secondary', !active);
          });
          showcase.querySelectorAll('[data-login-mockup]').forEach(function (m) {
            var active = m.dataset.loginMockup === theme;
            m.classList.toggle('hidden', !active);
            if (active) {
              m.classList.remove('crossfade-enter');
              void m.offsetWidth;
              m.classList.add('crossfade-enter');
            }
          });
        });

        // ── Contact form (Formspree) ──
        document.addEventListener('submit', function (e) {
          var form = e.target.closest('#contact-form');
          if (!form) return;
          e.preventDefault();
          var btn = form.querySelector('button[type="submit"]');
          btn.disabled = true;
          btn.textContent = 'Sending…';
          fetch('https://formspree.io/f/xnjoqarv', {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' },
          }).then(function (res) {
            var container = form.closest('[data-contact]');
            if (res.ok) {
              form.style.display = 'none';
              container.querySelector('[data-contact-success]').style.display = 'flex';
              form.reset();
            } else {
              btn.disabled = false;
              btn.textContent = 'Send Message';
              alert('Something went wrong. Please try again or reach out on GitHub.');
            }
          }).catch(function () {
            btn.disabled = false;
            btn.textContent = 'Send Message';
            alert('Network error. Please check your connection and try again.');
          });
        });

        document.addEventListener('click', function (e) {
          var btn = e.target.closest('[data-contact-reset]');
          if (!btn) return;
          var container = btn.closest('[data-contact]');
          container.querySelector('[data-contact-success]').style.display = 'none';
          var form = container.querySelector('#contact-form');
          form.style.display = '';
          form.reset();
        });
      })();
    </script>
  </body>
</html>
