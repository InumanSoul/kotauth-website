---
import { Zap, Palette, Server, Layers, Mail, Lock } from '@lucide/astro';
import GithubIcon from '@/components/icons/GithubIcon.astro';
import { themes } from '@/lib/authThemes';
import type { ThemeKey } from '@/lib/authThemes';

const themeKeys = Object.keys(themes) as ThemeKey[];

const points = [
  {
    Icon: Zap,
    title: 'Server-rendered, zero JS overhead',
    body: 'Auth pages are pure server-rendered HTML. No client-side framework, no hydration delay — first meaningful paint in under 100ms.',
  },
  {
    Icon: Palette,
    title: 'White-label per workspace',
    body: 'CSS custom properties injected at render time. Each tenant gets its own colors, logo, and favicon with zero rebuild or CDN invalidation.',
  },
  {
    Icon: Server,
    title: 'Complete screen set',
    body: 'Login, register, forgot password, reset password, accept invite, TOTP MFA, and email verification — all styled and production-ready.',
  },
  {
    Icon: Layers,
    title: 'Three presets, full customization',
    body: 'Start with Dark, Light, or Simple. Override any design token to match your brand without touching backend code.',
  },
];
---

<section data-auth-showcase class="py-24 lg:py-32 relative overflow-hidden">
  <div
    class="absolute pointer-events-none glow-drift top-1/2 left-0 -translate-x-1/2 -translate-y-1/2"
    style="width: 700px; height: 700px; background: radial-gradient(circle, rgba(0, 119, 168, 0.18) 0%, transparent 70%); filter: blur(40px);"
  ></div>

  <div class="section-container relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <div data-reveal>
        <span class="eyebrow mb-4 block">Auth Experience</span>
        <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight mb-4 font-mono">
          Auth screens that{' '}
          <span class="gradient-text">don't look like auth screens</span>
        </h2>
        <p class="text-lg text-kotauth-text-secondary mb-10 leading-relaxed">
          Production-ready login, registration, MFA, and account management pages —
          beautiful by default, fully white-labeled per tenant, zero rebuild required.
        </p>

        <div class="space-y-6">
          {points.map(({ Icon, title, body }, i) => (
            <div
              data-reveal
              data-reveal-delay={i * 80}
              class="flex gap-4"
            >
              <div class="w-9 h-9 bg-kotauth-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <Icon class="w-4 h-4 text-kotauth-primary" />
              </div>
              <div>
                <p class="text-sm font-semibold text-kotauth-text-primary font-mono mb-1">
                  {title}
                </p>
                <p class="text-sm text-kotauth-text-secondary leading-relaxed">
                  {body}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div data-reveal data-reveal-delay={200}>
        <div class="relative">
          <div class="absolute inset-0 bg-kotauth-primary/5 blur-3xl -z-10 rounded-3xl"></div>

          <div class="bg-kotauth-surface-1 border border-kotauth-surface-2 overflow-hidden shadow-2xl shadow-black/30">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-kotauth-surface-2 bg-kotauth-bg-secondary">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-kotauth-error/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-kotauth-warning/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-kotauth-success/60"></div>
              </div>
              <div class="flex-1 flex justify-center">
                <div class="bg-kotauth-surface-2 rounded px-4 py-1 text-[11px] font-mono text-kotauth-text-muted w-48 text-center">
                  auth.acme.com/login
                </div>
              </div>
              <div class="flex gap-1">
                {themeKeys.map((key) => (
                  <button
                    data-theme-btn={key}
                    class={`text-[10px] font-mono px-2 py-1 transition-all ${
                      key === 'dark'
                        ? 'bg-kotauth-primary text-white'
                        : 'text-kotauth-text-muted hover:text-kotauth-text-secondary'
                    }`}
                  >
                    {themes[key].label}
                  </button>
                ))}
              </div>
            </div>

            <div class="h-[360px] overflow-hidden relative">
              {themeKeys.map((key) => {
                const t = themes[key].preview;
                return (
                  <div
                    data-login-mockup={key}
                    class={`w-full h-full ${t.wrapper} p-6 flex flex-col items-center justify-center ${key !== 'dark' ? 'hidden' : ''}`}
                  >
                    <div class={`w-full max-w-[280px] rounded-lg p-6 ${t.card}`}>
                      <p class={`text-sm font-semibold ${t.heading} font-mono mb-0.5`}>Sign in</p>
                      <p class={`text-xs ${t.muted} mb-4`}>to continue to your workspace</p>

                      <div class="mb-2">
                        <div class={`w-full text-xs px-3 py-2 rounded ${t.input} flex items-center gap-2`}>
                          <Mail class="w-3 h-3 opacity-40 flex-shrink-0" />
                          <span class={`${t.inputPlaceholder} text-xs`}>Email address</span>
                        </div>
                      </div>

                      <div class="mb-4">
                        <div class={`w-full text-xs px-3 py-2 rounded ${t.input} flex items-center gap-2`}>
                          <Lock class="w-3 h-3 opacity-40 flex-shrink-0" />
                          <span class={`${t.inputPlaceholder} text-xs`}>••••••••••</span>
                        </div>
                      </div>

                      <button class={`w-full text-xs font-semibold py-2 rounded font-mono ${t.button} mb-4 transition-colors`}>
                        Continue
                      </button>

                      <div class={`flex items-center gap-2 mb-3 border-t ${t.divider}`}>
                        <span class={`text-[10px] ${t.muted} -mt-2.5 bg-inherit px-1.5 mx-auto`}>or</span>
                      </div>

                      <button class={`w-full text-xs py-2 rounded ${t.socialBtn} flex items-center justify-center gap-2 transition-colors`}>
                        <GithubIcon class="w-3 h-3" />
                        <span class={t.socialText}>Continue with GitHub</span>
                      </button>

                      <p class={`text-[10px] ${t.muted} text-center mt-4`}>
                        No account?{' '}
                        <span class={`${t.link} cursor-pointer font-medium`}>Sign up</span>
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <p class="text-center text-xs text-kotauth-text-muted font-mono mt-3">
            Click the theme tabs to preview — same URL, different tenant config
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
