---
import { Play, Users, Shield, Building2, KeyRound } from '@lucide/astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const DEMO_URL = 'https://demo.kotauth.com';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const highlightIcons = [Building2, Users, Shield, KeyRound];
const demoHighlights = i18n.liveDemo.highlights.map((h, idx) => ({
  icon: highlightIcons[idx],
  title: h.title,
  description: h.description,
}));
---

<section class="py-24 lg:py-32 relative overflow-hidden bg-kotauth-bg-secondary border-y border-kotauth-surface-2">
  <div class="section-container relative z-10">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow mb-4 block">{i18n.liveDemo.eyebrow}</span>
      <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight mb-4 font-mono">
        {i18n.liveDemo.titleStart}{' '}
        <span class="gradient-text">{i18n.liveDemo.titleHighlight}</span>
      </h2>
      <p class="text-lg text-kotauth-text-secondary">
        {i18n.liveDemo.description}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      {demoHighlights.map((item, index) => (
        <div data-reveal data-reveal-delay={index * 70}>
          <div class="bg-kotauth-surface-1 border border-kotauth-surface-2 p-5 h-full hover:border-kotauth-primary/30 transition-colors">
            <div class="w-9 h-9 bg-kotauth-primary/10 flex items-center justify-center mb-4">
              <item.icon class="w-4 h-4 text-kotauth-primary" />
            </div>
            <p class="text-sm font-semibold text-kotauth-text-primary font-mono mb-1.5">
              {item.title}
            </p>
            <p class="text-xs text-kotauth-text-tertiary font-mono leading-relaxed">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div data-reveal data-reveal-delay={300} class="flex justify-center">
      <a
        href={DEMO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-kotauth-primary hover:bg-kotauth-primary-light text-white px-8 h-12 font-mono text-sm transition-colors"
      >
        <Play class="w-4 h-4" />
        {i18n.liveDemo.launchDemo}
      </a>
    </div>
  </div>
</section>
