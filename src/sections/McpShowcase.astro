---
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);
const mcp = i18n.mcpShowcase;

// Split "tool_name ✓ result" into [name, result] for the two-line tool-call blocks.
const toolCalls = [mcp.chat.tool1Result, mcp.chat.tool2Result].map((s) => {
  const [name, ...rest] = s.split(' ✓ ');
  return { name, result: rest.join(' ✓ ') };
});

// Audit log lines: split "EVENT detail" and color the event.
const logLines = [
  { raw: mcp.chat.loginFailed, color: '#f59e0b' },
  { raw: mcp.chat.loginSuccess, color: '#34D399' },
  { raw: mcp.chat.userUpdated, color: '#94A3B8' },
].map(({ raw, color }) => {
  const idx = raw.indexOf(' ');
  return { event: raw.slice(0, idx), detail: raw.slice(idx + 1), color };
});
---

<section class="bg-[#0A0F14] relative overflow-hidden">
  <!-- ambient glow -->
  <div
    class="absolute top-[10%] right-[-5%] w-[600px] h-[600px] pointer-events-none"
    style="background: radial-gradient(circle, rgba(99,102,241,0.14), rgba(0,119,168,0.1) 45%, transparent 70%);"
  >
  </div>

  <div class="relative max-w-[1180px] mx-auto px-7 py-[110px] grid lg:grid-cols-2 gap-12 lg:gap-[60px] items-center">
    <!-- Left: copy + tool grid -->
    <div>
      <span class="font-mono text-[12.5px] font-medium tracking-[0.06em] uppercase text-[#00A3E0]">{mcp.eyebrow}</span>
      <h2 class="font-heading font-bold text-[32px] sm:text-[40px] leading-[1.08] tracking-[-0.025em] text-[#F0F4F8] mt-3.5 mb-4">
        {mcp.titleStart}{mcp.titleHighlight}
      </h2>
      <p class="text-[17px] leading-[1.62] font-medium text-[#94A3B8] mb-6">{mcp.subtitle}</p>

      <div class="flex items-center gap-3 mb-6">
        <code class="font-mono text-[13.5px] text-[#e6edf3] bg-[#0D1117] border border-[#1c2733] px-[13px] py-[9px]">{mcp.oneCommand}</code>
        <span class="text-[13.5px] text-[#5b6775]">{mcp.oneCommandLabel}</span>
      </div>

      <div class="grid grid-cols-2 gap-[9px]">
        {mcp.domains.map((d) => (
          <div class="flex items-center justify-between gap-2 bg-[#0d141b] border border-[#1c2733] px-[13px] py-2.5">
            <span class="text-[13.5px] font-semibold text-[#cdd9e5]">{d.label}</span>
            <span class="font-mono text-[11px] text-[#00A3E0] px-[7px] py-0.5" style="background: rgba(0,119,168,0.14);">{d.count}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: MCP chat window -->
    <div class="relative">
      <div class="relative bg-[#0D1117] border border-[#1c2733] overflow-hidden" style="box-shadow: 0 30px 60px -24px rgba(0,0,0,0.5);">
        <!-- title bar -->
        <div class="flex items-center gap-2 px-4 py-[13px] border-b border-[#1c2733] bg-[#0b0f14]">
          <span class="w-2.5 h-2.5 rounded-full bg-[#ef4444] opacity-80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b] opacity-80"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#10b981] opacity-80"></span>
          <span class="flex-1 text-center font-mono text-[11.5px] text-[#5b6775]">{mcp.mcpSession}</span>
        </div>
        <!-- conversation -->
        <div class="p-[18px] flex flex-col gap-[13px]">
          <!-- user -->
          <div class="self-end max-w-[88%] text-[#e6edf3] px-3.5 py-[11px] text-[13.5px] leading-[1.5]" style="background: rgba(0,119,168,0.16); border: 1px solid rgba(0,119,168,0.3);">
            {mcp.chat.userMessage}
          </div>
          <!-- assistant: actions -->
          <div class="self-start max-w-[92%] bg-[#161F28] border border-[#1c2733] px-3.5 py-3">
            <p class="text-[13.5px] leading-[1.5] text-[#94A3B8] mb-[11px]">{mcp.chat.assistantIntro}</p>
            {toolCalls.map((tc, i) => (
              <div class={`border-l-2 pl-[11px] ${i === 0 ? 'mb-[9px]' : ''}`} style="border-color: rgba(0,163,224,0.5);">
                <div class="font-mono text-[12px] text-[#00A3E0]">{tc.name}</div>
                <div class="font-mono text-[12px] text-[#34D399]">✓ {tc.result}</div>
              </div>
            ))}
          </div>
          <!-- assistant: summary -->
          <div class="self-start max-w-[92%] bg-[#161F28] border border-[#1c2733] px-3.5 py-3">
            <p class="text-[13.5px] leading-[1.5] text-[#94A3B8] mb-[9px]">{mcp.chat.summaryIntro}</p>
            <div class="bg-[#0b0f14] border border-[#1c2733] px-3 py-2.5 font-mono text-[11.5px] leading-[1.85]">
              {logLines.map((l) => (
                <div><span style={`color:${l.color};`}>{l.event}</span> <span class="text-[#5b6775]">{l.detail}</span></div>
              ))}
            </div>
            <p class="text-[13px] leading-[1.5] text-[#94A3B8] mt-[9px]">{mcp.chat.summaryAnalysis}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
