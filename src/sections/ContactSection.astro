---
import { MessageCircle, Bug, Mail, ArrowRight, CircleCheck } from '@lucide/astro';
import GithubIcon from '@/components/icons/GithubIcon.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const GITHUB_URL = 'https://github.com/InumanSoul/kotauth';
const ISSUES_URL = `${GITHUB_URL}/issues`;
const DISCUSSIONS_URL = `${GITHUB_URL}/discussions`;

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const channelIcons = [Bug, MessageCircle, GithubIcon];
const channelHrefs = [ISSUES_URL, DISCUSSIONS_URL, GITHUB_URL];
const channels = i18n.contactSection.channels.map((ch, idx) => ({
  Icon: channelIcons[idx],
  title: ch.title,
  description: ch.description,
  cta: ch.cta,
  href: channelHrefs[idx],
}));
---

<section id="contact" class="py-24 lg:py-32 bg-kotauth-bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-kotauth-primary/40 to-transparent"></div>

  <div class="section-container">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow mb-4 block">{i18n.contactSection.eyebrow}</span>
      <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight font-mono mb-4">
        {i18n.contactSection.title}
      </h2>
      <p class="text-kotauth-text-secondary text-lg">
        {i18n.contactSection.description}
      </p>
    </div>

    <div data-contact class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <div class="flex flex-col gap-6">
        {channels.map(({ Icon, title, description, cta, href }, index) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
            data-reveal-delay={index * 100}
            class="group flex gap-5 p-6 bg-kotauth-surface-1 border border-kotauth-surface-2 hover:border-kotauth-primary/50 transition-all duration-200"
          >
            <div class="flex-shrink-0 w-11 h-11 bg-kotauth-primary/10 flex items-center justify-center group-hover:bg-kotauth-primary/20 transition-colors">
              <Icon class="w-5 h-5 text-kotauth-primary" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-kotauth-text-primary font-mono mb-1 group-hover:text-kotauth-primary-light transition-colors">
                {title}
              </h3>
              <p class="text-sm text-kotauth-text-tertiary leading-relaxed mb-3">
                {description}
              </p>
              <span class="inline-flex items-center gap-1.5 text-xs font-mono text-kotauth-primary group-hover:text-kotauth-primary-light transition-colors">
                {cta}
                <ArrowRight class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
              </span>
            </div>
          </a>
        ))}

        <div
          data-reveal
          data-reveal-delay={300}
          class="p-5 border border-kotauth-surface-2 bg-kotauth-bg-primary/50"
        >
          <p class="text-xs text-kotauth-text-muted font-mono leading-relaxed">
            <span class="text-kotauth-text-tertiary">{i18n.contactSection.noteLabel}</span> {i18n.contactSection.noteText}
          </p>
        </div>
      </div>

      <div data-reveal data-reveal-delay={150}>
        <!-- Success state -->
        <div data-contact-success class="h-full flex-col items-center justify-center text-center p-12 bg-kotauth-surface-1 border border-kotauth-surface-2 gap-4" style="display: none;">
          <div class="w-14 h-14 bg-kotauth-success/10 flex items-center justify-center mb-2">
            <CircleCheck class="w-7 h-7 text-kotauth-success" />
          </div>
          <h3 class="text-xl font-semibold text-kotauth-text-primary font-mono">
            {i18n.contactSection.form.messageSent}
          </h3>
          <p class="text-kotauth-text-secondary text-sm max-w-xs">
            {i18n.contactSection.form.thankYou}
          </p>
          <button
            data-contact-reset
            class="mt-2 inline-flex items-center px-3 py-1.5 text-sm border border-kotauth-surface-2 text-kotauth-text-secondary hover:bg-kotauth-surface-2 font-mono transition-colors"
          >
            {i18n.contactSection.form.sendAnother}
          </button>
        </div>

        <!-- Form -->
        <form
          id="contact-form"
          class="bg-kotauth-surface-1 border border-kotauth-surface-2 p-8 flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="contact-name" class="text-xs font-mono text-kotauth-text-tertiary uppercase tracking-wider">
                {i18n.contactSection.form.name} <span class="text-kotauth-primary">*</span>
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder={i18n.contactSection.form.yourName}
                class="w-full bg-kotauth-bg-primary border border-kotauth-surface-2 px-4 py-2.5 text-sm text-kotauth-text-primary placeholder:text-kotauth-text-muted font-mono focus:outline-none focus:border-kotauth-primary transition-colors"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="contact-email" class="text-xs font-mono text-kotauth-text-tertiary uppercase tracking-wider">
                {i18n.contactSection.form.email} <span class="text-kotauth-primary">*</span>
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={i18n.contactSection.form.emailPlaceholder}
                class="w-full bg-kotauth-bg-primary border border-kotauth-surface-2 px-4 py-2.5 text-sm text-kotauth-text-primary placeholder:text-kotauth-text-muted font-mono focus:outline-none focus:border-kotauth-primary transition-colors"
              />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="contact-subject" class="text-xs font-mono text-kotauth-text-tertiary uppercase tracking-wider">
              {i18n.contactSection.form.subject} <span class="text-kotauth-primary">*</span>
            </label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="w-full bg-kotauth-bg-primary border border-kotauth-surface-2 px-4 py-2.5 text-sm text-kotauth-text-primary font-mono focus:outline-none focus:border-kotauth-primary transition-colors appearance-none cursor-pointer"
            >
              <option value="" disabled selected>{i18n.contactSection.form.selectTopic}</option>
              <option value="General Inquiry">{i18n.contactSection.form.generalInquiry}</option>
              <option value="Integration Help">{i18n.contactSection.form.integrationHelp}</option>
              <option value="Feature Request">{i18n.contactSection.form.featureRequest}</option>
              <option value="Security">{i18n.contactSection.form.security}</option>
              <option value="Partnership">{i18n.contactSection.form.partnership}</option>
              <option value="Other">{i18n.contactSection.form.other}</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="contact-message" class="text-xs font-mono text-kotauth-text-tertiary uppercase tracking-wider">
              {i18n.contactSection.form.message} <span class="text-kotauth-primary">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              placeholder={i18n.contactSection.form.messagePlaceholder}
              class="w-full bg-kotauth-bg-primary border border-kotauth-surface-2 px-4 py-2.5 text-sm text-kotauth-text-primary placeholder:text-kotauth-text-muted font-mono focus:outline-none focus:border-kotauth-primary transition-colors resize-none leading-relaxed"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-kotauth-primary hover:bg-kotauth-primary-light text-white font-mono h-11 transition-all inline-flex items-center justify-center gap-2 text-sm"
          >
            <Mail class="w-4 h-4" />
            {i18n.contactSection.form.sendMessage}
          </button>

          <p class="text-xs text-kotauth-text-muted font-mono text-center">
            {i18n.contactSection.form.urgentNote}{' '}
            <a href={DISCUSSIONS_URL} target="_blank" rel="noopener noreferrer" class="text-kotauth-primary hover:text-kotauth-primary-light underline underline-offset-2">
              {i18n.contactSection.form.githubDiscussions}
            </a>.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
