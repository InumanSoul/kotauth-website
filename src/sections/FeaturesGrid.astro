---
import {
  Container,
  Shield,
  Building2,
  Link,
  Bot,
  Archive,
  ArrowRight,
} from '@lucide/astro';
import FeatureCard from '@/components/FeatureCard.astro';
import { t, type Locale, defaultLocale, getLocalizedPath } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const icons = [Shield, Building2, Link, Archive, Bot, Container];
const features = i18n.featuresGrid.items.map((item, idx) => ({
  icon: icons[idx],
  title: item.title,
  description: item.description,
}));
---

<section id="features" class="py-24 lg:py-32 relative">
  <div class="section-container">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow mb-4 block">{i18n.featuresGrid.eyebrow}</span>
      <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight mb-4 font-mono">
        {i18n.featuresGrid.title}
      </h2>
      <p class="text-lg text-kotauth-text-secondary">
        {i18n.featuresGrid.subtitle}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-0">
      {features.map((feature, index) => (
        <div data-reveal data-reveal-delay={index * 100} class="h-full">
          <FeatureCard
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
          />
        </div>
      ))}
    </div>

    <div data-reveal class="text-center mt-12">
      <a
        href={getLocalizedPath('/features', locale)}
        class="inline-flex items-center gap-2 text-sm font-mono text-kotauth-primary hover:text-kotauth-primary-light transition-colors group"
      >
        {i18n.featuresGrid.exploreAll}
        <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>
