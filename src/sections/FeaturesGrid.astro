---
import {
  Container,
  Shield,
  Building2,
  Key,
  ShieldCheck,
  Bot,
  ArrowRight,
} from '@lucide/astro';
import FeatureCard from '@/components/FeatureCard.astro';

const features = [
  {
    icon: Shield,
    title: 'OAuth 2.0 & OpenID Connect',
    description:
      'Authorization Code + PKCE, Client Credentials, token introspection (RFC 7662), revocation (RFC 7009), and OIDC Discovery — all out of the box.',
  },
  {
    icon: Building2,
    title: 'Multi-Tenant by Design',
    description:
      'Every workspace gets its own RS256 key pair, isolated user base, and slug-routed API — /t/{workspace}/api/v1. Zero cross-tenant data leakage by design.',
  },
  {
    icon: Key,
    title: 'Flexible Authentication',
    description:
      'Password + TOTP with recovery codes, Google and GitHub OAuth with automatic account linking, and admin-initiated user invitations with branded email onboarding. MFA enforced per workspace.',
  },
  {
    icon: ShieldCheck,
    title: 'Security That Ships by Default',
    description:
      'bcrypt passwords, AES-256-GCM encryption at rest (RSA keys, SMTP creds, TOTP secrets), SHA-256 API key hashing, strict CSP, SRI on all JS, CSRF protection, and tiered rate limiting (login, MFA, password reset) — hardened before your first deploy.',
  },
  {
    icon: Bot,
    title: 'AI-Native Management (MCP)',
    description:
      'Manage users, roles, sessions, and audit logs from Claude, Cursor, or any MCP client. 21 tools, scope-based access, zero custom code. npx @kotauth/mcp to get started.',
  },
  {
    icon: Container,
    title: 'Docker-Native Deployment',
    description:
      '~120 MB  multi-stage image on GHCR. One-command quickstart or bring your own .env. CLI tools for key generation and MFA recovery. HTTP compression, bundled Swagger UI, and Flyway migrations — works fully air-gapped.',
  },
];
---

<section id="features" class="py-24 lg:py-32 relative">
  <div class="section-container">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow mb-4 block">Features</span>
      <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight mb-4 font-mono">
        Everything you need for modern authentication
      </h2>
      <p class="text-lg text-kotauth-text-secondary">
        Complete identity infrastructure with the simplicity developers expect
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-0">
      {features.map((feature, index) => (
        <div data-reveal data-reveal-delay={index * 100} class="h-full">
          <FeatureCard
            icon={feature.icon}
            title={feature.title}
            description={feature.description}
          />
        </div>
      ))}
    </div>

    <div data-reveal class="text-center mt-12">
      <a
        href="/features"
        class="inline-flex items-center gap-2 text-sm font-mono text-kotauth-primary hover:text-kotauth-primary-light transition-colors group"
      >
        Explore all features and technical details
        <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</section>
