---
import { Check, X, Minus } from '@lucide/astro';
import GradientGlow from '@/components/GradientGlow.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const featureNames = i18n.comparisonTable.features;

const comparisonData: { kotauth: boolean | null; keycloak: boolean | null; saas: boolean | null | string }[] = [
  { kotauth: true, keycloak: true, saas: false },
  { kotauth: true, keycloak: false, saas: null },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: true, saas: false },
  { kotauth: true, keycloak: false, saas: false },
  { kotauth: true, keycloak: true, saas: false },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: null },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: false, saas: false },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: null },
  { kotauth: true, keycloak: false, saas: false },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: null },
  { kotauth: true, keycloak: true, saas: null },
  { kotauth: true, keycloak: true, saas: null },
  { kotauth: true, keycloak: false, saas: false },
  { kotauth: true, keycloak: false, saas: true },
  { kotauth: null, keycloak: true, saas: 'paid' },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: true },
  { kotauth: true, keycloak: true, saas: false },
  { kotauth: true, keycloak: true, saas: false },
];
const comparisons = comparisonData.map((row, idx) => ({
  feature: featureNames[idx],
  ...row,
}));
---

<section class="py-24 lg:py-32 relative overflow-hidden">
  <GradientGlow
    class="top-1/2 right-0 translate-x-1/2 -translate-y-1/2"
    size={600}
    color="rgba(0, 119, 168, 0.15)"
  />

  <div class="section-container relative z-10">
    <div data-reveal class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow mb-4 block">{i18n.comparisonTable.eyebrow}</span>
      <h2 class="text-3xl sm:text-4xl lg:text-[42px] font-semibold text-kotauth-text-primary leading-tight mb-4 font-mono">
        {i18n.comparisonTable.title}
      </h2>
      <p class="text-lg text-kotauth-text-secondary">
        {i18n.comparisonTable.subtitle}
      </p>
    </div>

    <div data-reveal>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[600px]">
          <thead>
            <tr class="border-b border-kotauth-surface-2">
              <th class="text-left py-4 px-4 text-sm font-medium text-kotauth-text-tertiary font-mono">
                {i18n.comparisonTable.headerFeature}
              </th>
              <th class="text-center py-4 px-4">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-kotauth-primary/10 border border-kotauth-primary/30">
                  <span class="text-sm font-semibold text-kotauth-primary font-mono">Kotauth</span>
                </div>
              </th>
              <th class="text-center py-4 px-4 text-sm font-medium text-kotauth-text-secondary font-mono">
                Keycloak
              </th>
              <th class="text-center py-4 px-4 text-sm font-medium text-kotauth-text-secondary font-mono">
                Auth0 / Clerk
              </th>
            </tr>
          </thead>
          <tbody>
            {comparisons.map((row) => (
              <tr class="border-b border-kotauth-surface-2/50 hover:bg-kotauth-surface-1/30 transition-colors">
                <td class="py-4 px-4 text-kotauth-text-primary font-mono">{row.feature}</td>
                <td class="py-4 px-4">
                  <div class="flex justify-center">
                    {row.kotauth === true && (
                      <div class="w-6 h-6 bg-kotauth-success/10 flex items-center justify-center">
                        <Check class="w-4 h-4 text-kotauth-success" />
                      </div>
                    )}
                    {row.kotauth === false && (
                      <div class="w-6 h-6 bg-kotauth-error/10 flex items-center justify-center">
                        <X class="w-4 h-4 text-kotauth-error" />
                      </div>
                    )}
                    {row.kotauth === null && (
                      <div class="w-6 h-6 bg-kotauth-surface-2 flex items-center justify-center">
                        <Minus class="w-3 h-3 text-kotauth-text-muted" />
                      </div>
                    )}
                  </div>
                </td>
                <td class="py-4 px-4">
                  <div class="flex justify-center">
                    {row.keycloak === true && (
                      <div class="w-6 h-6 bg-kotauth-success/10 flex items-center justify-center">
                        <Check class="w-4 h-4 text-kotauth-success" />
                      </div>
                    )}
                    {row.keycloak === false && (
                      <div class="w-6 h-6 bg-kotauth-error/10 flex items-center justify-center">
                        <X class="w-4 h-4 text-kotauth-error" />
                      </div>
                    )}
                    {row.keycloak === null && (
                      <div class="w-6 h-6 bg-kotauth-surface-2 flex items-center justify-center">
                        <Minus class="w-3 h-3 text-kotauth-text-muted" />
                      </div>
                    )}
                  </div>
                </td>
                <td class="py-4 px-4">
                  <div class="flex justify-center">
                    {row.saas === true && (
                      <div class="w-6 h-6 bg-kotauth-success/10 flex items-center justify-center">
                        <Check class="w-4 h-4 text-kotauth-success" />
                      </div>
                    )}
                    {row.saas === false && (
                      <div class="w-6 h-6 bg-kotauth-error/10 flex items-center justify-center">
                        <X class="w-4 h-4 text-kotauth-error" />
                      </div>
                    )}
                    {row.saas === 'paid' && (
                      <span class="text-sm text-kotauth-warning font-medium font-mono">$$$</span>
                    )}
                    {row.saas === null && (
                      <div class="w-6 h-6 bg-kotauth-surface-2 flex items-center justify-center">
                        <Minus class="w-3 h-3 text-kotauth-text-muted" />
                      </div>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
