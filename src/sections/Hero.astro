---
import { ArrowRight, Play } from '@lucide/astro';
import CodeBlock from '@/components/CodeBlock.astro';
import GradientGlow from '@/components/GradientGlow.astro';

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';
const DEMO_URL = 'https://demo.kotauth.com';

const codeContent = `# Try Kotauth — one command
$ curl -O https://raw.githubusercontent.com/\\
    inumansoul/kotauth/main/\\
    docker-compose.quickstart.yml
$ docker compose -f \\
    docker-compose.quickstart.yml up -d

Starting Kotauth Server v1.5.5...
✓ Identity server ready on port 8080
✓ Admin dashboard available at /admin
✓ Demo data loaded — two workspaces ready
✓ API documentation at /api/docs`;
---

<section class="relative min-h-[auto] lg:min-h-screen flex items-center pt-24 pb-16 lg:pt-[72px] lg:pb-0 overflow-hidden">
  <GradientGlow
    class="top-1/4 left-1/4 -translate-x-1/2"
    size={800}
    color="rgba(0, 119, 168, 0.22)"
  />
  <GradientGlow
    class="bottom-1/4 right-1/4 translate-x-1/2"
    size={600}
    color="rgba(0, 163, 224, 0.16)"
  />

  <div class="section-container relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="max-w-xl">
        <div data-reveal class="mb-6">
          <span class="eyebrow">Docker-Native Identity Platform</span>
        </div>

        <h1
          data-reveal
          data-reveal-delay="100"
          class="text-3xl sm:text-4xl md:text-5xl lg:text-[56px] font-bold text-kotauth-text-primary leading-[1.1] tracking-tight mb-6 font-mono"
        >
          Identity infrastructure for{' '}
          <span class="gradient-text">modern applications</span>
        </h1>

        <p
          data-reveal
          data-reveal-delay="200"
          class="text-lg text-kotauth-text-secondary leading-relaxed mb-8"
        >
          The self-hosted authentication platform that combines enterprise power with
          developer experience. Deploy in seconds, scale with confidence.
        </p>

        <div data-reveal data-reveal-delay="300" class="flex flex-wrap gap-4">
          <a
            href={DEMO_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-kotauth-primary hover:bg-kotauth-primary-light text-white px-6 h-12 font-mono text-sm transition-colors"
          >
            <Play class="w-4 h-4" />
            Try the Demo
          </a>
          <a
            href={`${GITHUB_URL}#try-it--one-command`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-kotauth-surface-2 text-kotauth-text-primary hover:bg-kotauth-surface-1 hover:border-kotauth-primary/50 px-6 h-12 font-mono text-sm transition-colors"
          >
            Get Started
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>

      <div data-reveal data-reveal-delay="400" class="relative min-w-0">
        <div class="relative min-w-0">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-kotauth-primary/10 blur-2xl"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-kotauth-primary-light/10 blur-2xl"></div>

          <CodeBlock
            code={codeContent}
            language="bash"
            class="relative shadow-2xl shadow-kotauth-primary/5"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-kotauth-bg-primary to-transparent pointer-events-none"></div>
</section>

<script is:inline>
  (function () {
    var glows = document.querySelectorAll('.glow-drift');
    if (!glows.length) return;

    var BASE_DURATION = 12;
    var MIN_DURATION = 2;
    var SCROLL_CEILING = 1200;
    var ticking = false;

    function update() {
      var scroll = Math.min(window.scrollY, SCROLL_CEILING);
      var ratio = scroll / SCROLL_CEILING;
      var duration = BASE_DURATION - ratio * (BASE_DURATION - MIN_DURATION);
      for (var i = 0; i < glows.length; i++) {
        glows[i].style.setProperty('--glow-duration', duration.toFixed(2) + 's');
      }
      ticking = false;
    }

    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });

    update();
  })();
</script>
