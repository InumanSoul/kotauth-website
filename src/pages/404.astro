---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ArrowLeft } from '@lucide/astro';
---

<BaseLayout title="Page Not Found — Kotauth" description="The page you're looking for doesn't exist.">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <span class="text-7xl font-bold text-kotauth-primary/20 mb-4">404</span>
    <h1 class="text-2xl sm:text-3xl font-bold text-kotauth-text-primary mb-3">
      Page not found
    </h1>
    <p class="text-kotauth-text-secondary max-w-md mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-kotauth-primary text-white font-medium hover:bg-kotauth-primary/90 transition-colors"
    >
      <ArrowLeft class="w-4 h-4" />
      Back to home
    </a>
  </section>
</BaseLayout>
