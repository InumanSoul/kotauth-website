---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';
const DEMO_URL = 'https://demo.kotauth.com';
const QUICKSTART_URL = 'https://docs.kotauth.com/getting-started/quickstart/';

const categories = [
  {
    label: 'Authentication & protocols',
    subtitle: 'Standards-based auth that drops into any client.',
    items: [
      {
        title: 'OAuth 2.0 & OpenID Connect',
        body: 'Authorization Code with PKCE, Client Credentials, token rotation, introspection, revocation and OIDC Discovery. Spec-compliant, so any OIDC client library works out of the box.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/></svg>',
      },
      {
        title: 'Passwordless login',
        body: 'Magic-link and Email OTP login with 15-minute one-time tokens and same-device binding. User-enumeration safe. Workspaces can go fully passwordless.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M4 4h16v16H4zM4 7l8 5 8-5"/></svg>',
      },
      {
        title: 'Multi-factor auth',
        body: 'TOTP-based MFA with replay detection and lockout protection. Enforced per workspace and preserved across every passwordless flow.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="5" y="11" width="14" height="10"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>',
      },
    ],
  },
  {
    label: 'Multi-tenancy & access',
    subtitle: 'One instance, many products, fully isolated.',
    items: [
      {
        title: 'Isolated workspaces',
        body: 'Separate user directories, per-tenant RS256 key pairs with admin-initiated rotation, slug-routed APIs and independent security policies.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01"/></svg>',
      },
      {
        title: 'RBAC & groups',
        body: 'Roles with composite inheritance, group membership and client default roles. Fine-grained access control with no external services to run.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M16 7h5M18.5 4.5v5"/></svg>',
      },
      {
        title: 'Custom JWT claims',
        body: 'Project user attributes into tokens with claim mappers. Shape the exact JWT each application receives, with no code required.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg>',
      },
    ],
  },
  {
    label: 'Security & compliance',
    eyebrow: 'Hardened by default',
    subtitle: 'The controls auditors ask about, built in from day one.',
    dark: true,
    items: [
      {
        title: 'Encrypted at rest',
        body: 'Secrets sealed with AES-256-GCM. Backups derive keys with PBKDF2 at 600k iterations before encryption.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="4" y="10" width="16" height="11"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 15v2"/></svg>',
      },
      {
        title: 'Breached password checks',
        body: 'HIBP k-anonymity blocks known-compromised passwords at registration and reset, without leaking the password.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-4Z"/><path d="M12 8v4M12 16h.01"/></svg>',
      },
      {
        title: 'Account protection',
        body: 'Account lockout, refresh-token replay detection with family revocation, and silent SSO with prompt=none.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
      },
      {
        title: 'Immutable audit trail',
        body: '65+ event types in an append-only log. Query by actor, action or time from the API or your AI assistant.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M8 13h8M8 17h5"/></svg>',
      },
    ],
  },
  {
    label: 'Developer experience',
    subtitle: 'A consistent surface that rewards reading the docs once.',
    items: [
      {
        title: 'One consistent REST API',
        body: 'The same shape across every resource, with scoped API keys per workspace and RFC-compliant errors. Keys read as Bearer kauth_{slug}_{key}.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M8 6 2 12l6 6M16 6l6 6-6 6"/></svg>',
      },
      {
        title: 'OpenAPI & built-in CLI',
        body: 'Bundled Swagger UI and five built-in CLI tools. Everything is documented and everything is scriptable.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>',
      },
      {
        title: 'Workspace-routed endpoints',
        body: 'Predictable routing at /t/{slug}/api/v1. One instance serves every tenant with no ambiguity about who you are talking to.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>',
      },
    ],
  },
  {
    label: 'Deployment & operations',
    subtitle: 'Boring to run, which is exactly what you want from auth.',
    items: [
      {
        title: 'Docker-native',
        body: 'A ~120 MB image on GHCR. Runs non-root as UID 10001, read-only filesystem, no-new-privileges. One-command quickstart and Flyway auto-migrations handle the rest. Fully air-gapped capable.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="10" width="4" height="4"/><rect x="8" y="10" width="4" height="4"/><rect x="13" y="10" width="4" height="4"/><rect x="8" y="5" width="4" height="4"/><path d="M19 11c1.5 0 2.5-1 2.5-1M3 14c0 3 2 5 7 5 7 0 11-4 11-8"/></svg>',
      },
      {
        title: 'Backup & restore',
        body: 'Portable, encrypted tenant snapshots via CLI or admin API, with schema-version validation on import.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/></svg>',
      },
      {
        title: 'Scale-out ready',
        body: 'Redis-backed distributed sessions and bring-your-own database support for production deployments.',
        icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 12h4l3 8 4-16 3 8h4"/></svg>',
      },
    ],
  },
];
---

<BaseLayout
  title={i18n.pages.features.title}
  description={i18n.pages.features.description}
  path="/features"
>
  <!-- Header -->
  <section class="relative px-7 pt-32 pb-20 text-center overflow-hidden">
    <div class="max-w-[760px] mx-auto">
      <span class="eyebrow mb-4 block">Features</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-[56px] leading-[1.05] tracking-[-0.025em] text-kotauth-text-primary mb-4">
        Everything you need for identity infrastructure
      </h1>
      <p class="max-w-[620px] mx-auto text-lg text-kotauth-text-secondary leading-relaxed">
        A complete authentication platform. Spec-compliant protocols, real multi-tenancy, hardened security, and a developer experience that respects your time.
      </p>
    </div>
  </section>

  <!-- Categories -->
  {categories.map((cat) => (
    <section class={`py-16 ${cat.dark ? 'dark-section bg-kotauth-bg-primary' : ''}`}>
      <div class="section-container">
        <div class="mb-9 max-w-2xl">
          {cat.eyebrow && <span class="eyebrow mb-3 block">{cat.eyebrow}</span>}
          <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-kotauth-text-primary mb-2">
            {cat.label}
          </h2>
          <p class="text-kotauth-text-secondary">
            {cat.subtitle}
          </p>
        </div>

        <div class={`grid sm:grid-cols-2 ${cat.items.length === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3'} gap-5`}>
          {cat.items.map((item) => (
            <div
              class="bg-kotauth-surface-1 border border-kotauth-surface-2 p-[28px]"
              style="box-shadow:0 1px 3px rgba(15,22,41,0.05)"
            >
              <div
                class="w-[44px] h-[44px] bg-kotauth-primary/10 text-kotauth-primary flex items-center justify-center mb-5"
                set:html={item.icon}
              />
              <h3 class="font-heading text-[17px] font-bold text-kotauth-text-primary mb-2">
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed text-kotauth-text-secondary">
                {item.body}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="px-7 pb-28">
    <div class="section-container">
      <div class="dark-section relative bg-kotauth-bg-primary px-6 sm:px-12 py-[72px] text-center overflow-hidden">
        <h2 class="font-heading font-bold text-3xl sm:text-[42px] leading-[1.08] tracking-[-0.025em] text-kotauth-text-primary mb-4">
          See it all running live
        </h2>
        <p class="max-w-[480px] mx-auto text-kotauth-text-secondary mb-8">
          Explore a seeded instance, or deploy your own in under a minute.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href={QUICKSTART_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white text-[#0A0F14] px-6 h-[50px] text-[15.5px] font-semibold transition-transform hover:-translate-y-px"
          >
            Get started free
          </a>
          <a
            href={DEMO_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-white/20 text-white hover:border-white/40 hover:bg-white/5 px-6 h-[50px] text-[15.5px] font-semibold transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Try the demo
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
