---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/sections/Hero.astro';
import WhySelfHost from '@/sections/WhySelfHost.astro';
import FeaturesGrid from '@/sections/FeaturesGrid.astro';
import McpShowcase from '@/sections/McpShowcase.astro';
import AuthShowcase from '@/sections/AuthShowcase.astro';
import CompareSection from '@/sections/CompareSection.astro';
import CTASection from '@/sections/CTASection.astro';
import { t } from '@/i18n';

const i18n = t('pt-br');
---

<BaseLayout
  title={i18n.pages.index.title}
  description={i18n.pages.index.description}
  path="/pt-br"
>
  <Hero />
  <WhySelfHost />
  <FeaturesGrid />
  <McpShowcase />
  <AuthShowcase />
  <CompareSection />
  <CTASection />
</BaseLayout>
