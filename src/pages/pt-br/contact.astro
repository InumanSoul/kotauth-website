---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';

const channels = [
  {
    title: 'Relatar bugs',
    body: 'Encontrou algo quebrado? Abra uma issue no GitHub com os passos de reprodução e nós vamos triá-la.',
    cta: 'Abrir uma issue',
    href: `${GITHUB_URL}/issues/new`,
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/>',
  },
  {
    title: 'Comunidade',
    body: 'Perguntas, ideias e discussão geral. O GitHub Discussions é onde a comunidade vive.',
    cta: 'Entrar nas discussions',
    href: `${GITHUB_URL}/discussions`,
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  },
  {
    title: 'Contribuir',
    body: 'Quer adicionar um recurso ou melhorar o código? Comece lendo o guia de contribuição.',
    cta: 'Ver o repositório',
    href: GITHUB_URL,
    icon: '<path d="M8 6 2 12l6 6M16 6l6 6-6 6"/>',
  },
];

const topics = [
  'Dúvida geral',
  'Ajuda com integração',
  'Solicitação de recurso',
  'Segurança',
  'Parceria',
];
---

<BaseLayout
  title={i18n.pages.contact.title}
  description={i18n.pages.contact.description}
  path="/contact"
>
  <!-- Page header -->
  <section class="relative overflow-hidden pt-32 pb-14 text-center">
    <div class="section-container">
      <div class="max-w-[680px] mx-auto">
        <span class="eyebrow mb-3.5 block">Contato</span>
        <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-[56px] leading-[1.05] tracking-[-0.025em] text-kotauth-text-primary mb-[18px]">
          Entre em contato
        </h1>
        <p class="text-lg font-medium text-kotauth-text-secondary leading-relaxed">
          Kotauth é um projeto de código aberto e a maioria das conversas acontece em público, de propósito. Escolha o canal certo abaixo ou envie uma mensagem direta.
        </p>
      </div>
    </div>
  </section>

  <!-- Main: channels + form -->
  <section class="pt-5 pb-24">
    <div class="section-container">
      <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 items-start">

        <!-- Left: channels + note -->
        <div>
          <div class="flex flex-col gap-4">
            {channels.map((ch) => (
              <a
                href={ch.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex gap-4 items-start bg-kotauth-surface-1 border border-kotauth-surface-2 py-[22px] px-6 shadow-[0_1px_3px_rgba(15,22,41,0.04)] hover:border-kotauth-text-muted hover:-translate-y-0.5 transition-all"
              >
                <div class="w-[42px] h-[42px] flex-shrink-0 bg-kotauth-primary/10 flex items-center justify-center text-kotauth-primary">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" set:html={ch.icon} />
                </div>
                <div>
                  <h3 class="font-heading text-base font-bold text-kotauth-text-primary mb-1">{ch.title}</h3>
                  <p class="text-[13.5px] leading-[1.55] text-kotauth-text-secondary mb-2">{ch.body}</p>
                  <span class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-kotauth-primary">
                    {ch.cta}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M7 17 17 7M9 7h8v8"/></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
          <div class="bg-kotauth-bg-secondary border border-kotauth-surface-2 border-l-[3px] border-l-kotauth-primary p-5 mt-[18px]">
            <p class="text-[13px] leading-relaxed text-kotauth-text-secondary">
              <strong class="font-bold text-kotauth-text-primary">Nota.</strong> Este é um projeto de código aberto mantido nas horas vagas, então os tempos de resposta variam. Para divulgações de segurança, use o formulário com o assunto definido como Segurança.
            </p>
          </div>
        </div>

        <!-- Right: form -->
        <div class="bg-kotauth-surface-1 border border-kotauth-surface-2 p-9 shadow-[0_8px_30px_-16px_rgba(15,22,41,0.14)]">
          <h2 class="font-heading text-[22px] font-bold text-kotauth-text-primary mb-6">Enviar uma mensagem</h2>
          <form
            id="contact-form"
            action="https://formspree.io/f/kotauth"
            method="POST"
            class="space-y-4"
          >
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-[12.5px] font-semibold text-kotauth-text-secondary mb-1.5">Nome</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full border border-kotauth-surface-2 px-3 h-10 text-sm text-kotauth-text-primary bg-white focus:outline-none focus:border-kotauth-primary transition-colors"
                  placeholder="Seu nome"
                />
              </div>
              <div>
                <label for="email" class="block text-[12.5px] font-semibold text-kotauth-text-secondary mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full border border-kotauth-surface-2 px-3 h-10 text-sm text-kotauth-text-primary bg-white focus:outline-none focus:border-kotauth-primary transition-colors"
                  placeholder="voce@exemplo.com"
                />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-[12.5px] font-semibold text-kotauth-text-secondary mb-1.5">Assunto</label>
              <select
                id="subject"
                name="subject"
                class="w-full border border-kotauth-surface-2 px-3 h-10 text-sm text-kotauth-text-secondary bg-white focus:outline-none focus:border-kotauth-primary transition-colors appearance-none cursor-pointer"
              >
                <option value="" disabled selected>Selecione um tópico</option>
                {topics.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
            <div>
              <label for="message" class="block text-[12.5px] font-semibold text-kotauth-text-secondary mb-1.5">Mensagem</label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                placeholder="Descreva sua pergunta ou solicitação em detalhes"
                class="w-full border border-kotauth-surface-2 px-3 py-2.5 text-sm text-kotauth-text-primary bg-white focus:outline-none focus:border-kotauth-primary transition-colors resize-y"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-kotauth-primary hover:bg-kotauth-primary-light text-white py-3 text-[15px] font-semibold transition-colors"
            >
              Enviar mensagem
            </button>
          </form>
          <p class="mt-3.5 text-[12.5px] text-kotauth-text-muted text-center">
            Para assuntos urgentes, use o <a href={`${GITHUB_URL}/discussions`} target="_blank" rel="noopener noreferrer" class="text-kotauth-primary font-semibold hover:text-kotauth-primary-light transition-colors">GitHub Discussions</a>.
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
