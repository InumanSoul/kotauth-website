---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';

const sections = [
  {
    title: 'Hash de senhas',
    body: 'As senhas são processadas com hash via bcrypt e um salt por credencial. O texto em claro nunca é armazenado ou registrado, e os fatores de trabalho são ajustados para o hardware atual.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="5" y="11" width="14" height="10"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>',
  },
  {
    title: 'Criptografia em repouso',
    body: 'Segredos sensíveis são selados com AES-256-GCM. Os backups de tenant derivam chaves com PBKDF2 a 600k iterações antes de o envelope ser criptografado.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="4" y="10" width="16" height="11"/><path d="M8 10V7a4 4 0 0 1 8 0v3M12 15v2"/></svg>',
  },
  {
    title: 'Segurança de tokens',
    body: 'Tokens de acesso de curta duração, refresh tokens rotativos e detecção de replay com revogação completa da família quando um token reutilizado é detectado.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/></svg>',
  },
  {
    title: 'Rate limiting e bloqueio',
    body: 'Os endpoints de autenticação têm rate limiting, e falhas repetidas disparam o bloqueio da conta. As tentativas de TOTP têm sua própria proteção contra replay e bloqueio.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
  },
  {
    title: 'Isolamento de tenants',
    body: 'Cada workspace tem seu próprio diretório de usuários, chaves de assinatura RS256 e política CORS. Um comprometimento em um tenant não consegue alcançar outro.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01"/></svg>',
  },
  {
    title: 'Logging de auditoria completo',
    body: 'Mais de 65 tipos de evento são registrados em uma trilha append-only. Cada ação administrativa é atribuível a um ator, um momento e uma origem.',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M8 13h8M8 17h5"/></svg>',
  },
];

const hardening = [
  { label: 'Contêiner sem root', body: 'Roda como UID 10001 com no-new-privileges definido.' },
  { label: 'Sistema de arquivos somente leitura', body: 'Superfície de runtime imutável com montagens graváveis explícitas.' },
  { label: 'Capaz de operar air-gapped', body: 'Nenhuma chamada externa é necessária para rodar em redes isoladas.' },
  { label: 'Chaves de bootstrap a partir do env', body: 'As chaves de API iniciais são gerenciadas por env, nunca gravadas em disco em texto em claro.' },
];

const checkIcon =
  '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="m5 12 5 5L20 6"/></svg>';
---

<BaseLayout
  title={i18n.pages.security.title}
  description={i18n.pages.security.description}
  path="/security"
>
  <!-- Header -->
  <section class="relative px-7 pt-32 pb-20 text-center overflow-hidden">
    <div
      class="absolute -top-[120px] left-1/2 -translate-x-1/2 w-[900px] h-[420px] pointer-events-none"
      style="background:radial-gradient(ellipse at center,rgba(0,119,168,.1),transparent 70%)"
    >
    </div>
    <div class="relative max-w-[760px] mx-auto">
      <span class="eyebrow">Segurança</span>
      <h1
        class="font-heading font-bold text-4xl sm:text-5xl lg:text-[56px] leading-[1.05] tracking-[-0.025em] mt-3.5 mb-4 text-kotauth-text-primary"
      >
        Segurança que você pode verificar
      </h1>
      <p class="max-w-[620px] mx-auto text-lg leading-[1.6] text-kotauth-text-secondary">
        O Kotauth é open source, então a segurança é auditável, não apenas afirmada. Veja como a plataforma protege credenciais, dados e sessões.
      </p>
    </div>
  </section>

  <!-- Core security properties -->
  <section class="max-w-[1180px] mx-auto px-7 pt-[30px] pb-[70px]">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[18px]">
      {sections.map((s) => (
        <div
          class="bg-kotauth-surface-1 border border-kotauth-surface-2 py-[26px] px-6"
          style="box-shadow:0 1px 3px rgba(15,22,41,0.04)"
        >
          <div
            class="w-[40px] h-[40px] bg-kotauth-primary/10 flex items-center justify-center text-kotauth-primary mb-4"
            set:html={s.icon}
          />
          <h3 class="font-heading text-[17px] font-bold mb-2 text-kotauth-text-primary">{s.title}</h3>
          <p class="text-sm leading-[1.6] text-kotauth-text-secondary">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Runtime hardening dark band -->
  <section class="dark-section relative overflow-hidden bg-kotauth-bg-primary">
    <div
      class="absolute -top-[10%] -right-[5%] w-[560px] h-[560px] pointer-events-none"
      style="background:radial-gradient(circle,rgba(0,119,168,.16),transparent 70%)"
    >
    </div>
    <div
      class="relative max-w-[1180px] mx-auto px-7 py-[90px] grid lg:grid-cols-2 gap-14 items-center"
    >
      <div>
        <span class="eyebrow">Hardening de runtime</span>
        <h2
          class="font-heading font-bold text-3xl lg:text-[34px] leading-[1.1] tracking-[-0.025em] mt-3 mb-4 text-kotauth-text-primary"
        >
          Protegido por padrão
        </h2>
        <p class="text-base leading-[1.62] text-kotauth-text-secondary">
          O contêiner vem com padrões seguros para que um deploy recém-criado não seja um alvo fácil. Sem root, sem sistema de arquivos gravável, sem escalada de privilégios.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        {hardening.map((h) => (
          <div class="flex gap-3 items-start bg-kotauth-surface-1 border border-kotauth-surface-2 py-4 px-[18px]">
            <span class="text-[#34D399] mt-px shrink-0" set:html={checkIcon} />
            <div>
              <div class="text-[14.5px] font-bold mb-0.5 text-kotauth-text-primary">{h.label}</div>
              <div class="text-[13px] leading-[1.5] text-kotauth-text-secondary">{h.body}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Responsible disclosure -->
  <section class="max-w-[920px] mx-auto px-7 pt-20 pb-28">
    <div
      class="bg-kotauth-bg-secondary border border-kotauth-surface-2 border-l-[3px] border-l-kotauth-primary py-10 px-[38px]"
    >
      <h2
        class="font-heading font-bold text-[26px] tracking-[-0.02em] mb-3 text-kotauth-text-primary"
      >
        Divulgação responsável
      </h2>
      <p class="text-[15.5px] leading-[1.65] text-kotauth-text-secondary mb-[18px]">
        Encontrou uma vulnerabilidade? Agradecemos a divulgação coordenada. Use o formulário de contato com o assunto definido como Security e, por favor, não abra uma issue pública para relatos sensíveis. Buscamos confirmar relatos válidos rapidamente e manteremos você atualizado até a resolução.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-kotauth-primary hover:bg-kotauth-primary-light px-[22px] h-[46px] transition-colors"
      >
        Relatar uma vulnerabilidade
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
