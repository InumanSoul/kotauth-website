---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  Shield,
  Building2,
  Key,
  ShieldCheck,
  Webhook,
  Container,
  Users,
  Palette,
  Bot,
  ArrowRight,
  Play,
  Lock,
  FileCode,
  FingerprintPattern,
  RefreshCw,
  ShieldAlert,
  LogOut,
  Tags,
  Link,
  Archive,
  Globe,
  Database,
  UserCheck,
  LayoutGrid,
  ShieldBan,
  Mail,
  CircleUserRound,
  Paintbrush,
  Target,
} from '@lucide/astro';
import GradientGlow from '@/components/GradientGlow.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import AuthShowcase from '@/sections/AuthShowcase.astro';
import { t, getLocalizedPath } from '@/i18n';

const i18n = t('es');

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';
const DEMO_URL = 'https://demo.kotauth.com';

const allFeatures = [
  {
    icon: Shield,
    title: 'OAuth 2.0 y OpenID Connect',
    description: 'Authorization Code + PKCE (obligatorio para todos los clientes públicos), Client Credentials para comunicación máquina a máquina, rotación de Refresh Token con invalidación inmediata, introspección de tokens (RFC 7662), revocación (RFC 7009), OIDC Discovery en /.well-known/openid-configuration y logout iniciado por el RP con id_token_hint. Cualquier librería cliente compatible con OIDC funciona sin modificación.',
  },
  {
    icon: Target,
    title: 'Indicadores de Recurso RFC 8707',
    description: 'Tokens máquina a máquina dirigidos a una audiencia específica. El parámetro resource en el endpoint de token (grant client_credentials) permite que los tokens lleven el identificador de la API objetivo como claim aud en lugar del client_id del solicitante. Registro de APIs (admin: /settings/apis) proporciona CRUD con scope de workspace para identificadores de audiencia. Pantalla "APIs Autorizadas" por cliente con autorización por checkbox y badges de deshabilitación. Los metadatos de Discovery anuncian resource_indicators_supported: true para que las librerías cliente compatibles con RFC 8707 habiliten el parámetro automáticamente. Jerarquía: resource > columna audience por cliente > client_id. Recursos desconocidos o no autorizados producen invalid_target 400 según RFC 8707, nunca un token silenciosamente amplio.',
  },
  {
    icon: Building2,
    title: 'Multi-Tenant por Diseño',
    description: 'Cada workspace obtiene su propio par de claves RS256 provisionado en el primer uso, sin clave de firma compartida entre tenants. La rotación de claves iniciada por el admin permite generar una nueva clave de firma, promoverla a activa y retirar la anterior cuando todos los tokens hayan expirado. Directorios de usuarios aislados, APIs enrutadas por slug (/t/{workspace}/api/v1), URLs de issuer independientes y TTLs de tokens configurables. La misma dirección de email se trata como una identidad completamente separada en cada workspace.',
  },
  {
    icon: Key,
    title: 'Autenticación Flexible',
    description: 'Autenticación por contraseña con seguimiento de historial (evita la reutilización de las últimas N contraseñas), verificación contra listas negras, aplicación de complejidad y edad máxima configurable con expiración forzada. MFA con TOTP (RFC 6238) con códigos de recuperación. OAuth con Google y GitHub con vinculación automática de cuenta por email. Los usuarios pueden ver y gestionar identidades sociales conectadas desde el portal de autoservicio. Invitaciones de usuario iniciadas por el admin con email personalizado, enlaces de activación de 72 horas y configuración automática de cuenta. La aplicación de MFA es configurable por workspace.',
  },
  {
    icon: ShieldAlert,
    title: 'Bloqueo de Cuenta y Protección contra Fuerza Bruta',
    description: 'Umbral configurable de intentos fallidos de login con bloqueo automático de cuenta. Los usuarios bloqueados reciben una notificación por email con un enlace de restablecimiento de contraseña. Los administradores pueden desbloquear cuentas manualmente. Combinado con rate limiting por IP y alcance por workspace, cada capa de la ruta de login está protegida. Los eventos de cambio de contraseña y bloqueo de cuenta activan emails de notificación de seguridad asíncronos.',
  },
  {
    icon: Users,
    title: 'RBAC con Grupos y Herencia',
    description: 'Asigna roles directamente a usuarios o a través de grupos. Los grupos heredan roles, los usuarios heredan la membresía del grupo. La herencia compuesta significa que un usuario en múltiples grupos acumula todos los permisos. La revocación de acceso es inmediata, sin esperar la expiración del token. Revocación de sesión iniciada por admin y por usuario, más revocación masiva desde la consola de administración.',
  },
  {
    icon: Tags,
    title: 'JWT Claims Personalizados',
    description: 'Adjunta atributos clave-valor por usuario y proyéctalos en tokens JWT de acceso y/o ID mediante claim mappers a nivel de tenant. 41 nombres de claims OIDC reservados están bloqueados para evitar sobreescribir claims estándar (sub, iss, email, etc.). Caché de claim mappers con TTL de 60 segundos para mantener la emisión de tokens rápida. Los cambios se propagan en la siguiente emisión de token o inmediatamente al renovar el refresh token. Consola de administración y API REST para gestionar atributos y mappers. Máximo 20 mappers por tenant para prevenir inflado del JWT. Salvaguarda de PII: la UI de admin advierte que los valores de atributos fluyen sin cifrar hacia los tokens.',
  },
  {
    icon: ShieldCheck,
    title: 'Seguridad Incluida por Defecto',
    description: 'Hashing de contraseñas con bcrypt, cifrado AES-256-GCM en reposo (claves privadas RSA, credenciales SMTP, secretos TOTP), API keys hasheadas con SHA-256, cookies firmadas con HMAC-SHA256, CSP estricto sin JavaScript inline, integridad SRI en todos los bundles, protección CSRF, cookies SameSite, prevención de redirección abierta, KAUTH_SECRET_KEY obligatorio. La detección de replay de refresh-token revoca toda la familia de sesiones ante una reutilización. Protección contra replay TOTP con bloqueo por enrollment. El contenedor se ejecuta como non-root (UID 10001) con no-new-privileges y filesystem de solo lectura. Normalización de errores de login con ecualización de tiempos evita la enumeración de usuarios. La aplicación de issuer JWT bloquea la reutilización de tokens entre tenants. El opt-in de proxy de confianza (KAUTH_TRUSTED_PROXY) previene el bypass de rate-limit mediante spoofing de headers. Cadena HMAC sobre el log de auditoría: cada fila lleva prev_hash y row_hash vía HMAC-SHA256 con clave KAUTH_SECRET_KEY, la manipulación o reordenamiento rompe la cadena y es detectada por el comando CLI verify-audit-chain. PKCE S256 usa comparación en tiempo constante. Header Server de respuesta suprimido.',
  },
  {
    icon: Webhook,
    title: 'Webhooks en Tiempo Real',
    description: 'Payloads firmados con HMAC-SHA256 entregados para 8 tipos de eventos: user.created, user.updated, user.deleted, login.success, login.failed, password.reset, mfa.enrolled y session.revoked. URLs de endpoint configurables con lógica de reintento con backoff exponencial (3 intentos: inmediato, 5 min, 30 min). Reacciona a eventos de identidad sin hacer polling.',
  },
  {
    icon: Palette,
    title: 'Páginas de Auth White-Label',
    description: 'Variables CSS inyectadas del lado del servidor en tiempo de render, sin invalidación de caché CDN, sin necesidad de rebuild. Color primario, fondo, logo y favicon personalizados por tenant. Tres presets incluidos: Dark, Light y Simple. La personalización está completamente aislada: cambiar el tema de un tenant no afecta a los demás.',
  },
  {
    icon: Container,
    title: 'Despliegue Nativo de Docker',
    description: 'Imagen multi-stage de ~120 MB publicada en GHCR (ghcr.io/inumansoul/kotauth). Se ejecuta como usuario non-root (UID 10001) con no-new-privileges, cap_drop: ALL y filesystem de solo lectura. Quickstart de un comando con datos de demo precargados, o trae tu propio .env para una configuración personalizada. Las migraciones Flyway se ejecutan automáticamente al iniciar, sin scripts de init, sin configuración manual del esquema. Herramientas CLI integradas (generate-secret-key, reset-admin-mfa, hash-api-key, export-tenant, import-tenant, verify-audit-chain) para provisión de claves, recuperación de emergencia, verificación de integridad de auditoría y operaciones de backup. Inyección de secretos basada en archivos (convención *_FILE): KAUTH_SECRET_KEY, DB_PASSWORD, KAUTH_REDIS_PASSWORD, KAUTH_BOOTSTRAP_ADMIN_PASSWORD y KAUTH_BOOTSTRAP_API_KEYS aceptan un sibling _FILE apuntando a una ruta del filesystem, compatible con Docker Swarm secrets, Kubernetes mounted secrets y systemd LoadCredential=. Dos archivos compose raíz: docker-compose.yml para desarrollo local y docker-compose.prod.yml para producción con Caddy TLS. Bootstrap de API keys vía variable de entorno para automatización CI/CD. Bloqueo de dependencias Gradle con verificación en CI y Dependabot para alertas semanales de vulnerabilidades.',
  },
  {
    icon: Bot,
    title: 'Gestión Nativa con IA (MCP)',
    description: 'Gestiona toda tu infraestructura de identidad desde Claude, Cursor o cualquier asistente de IA compatible con MCP. El paquete @kotauth/mcp expone 33 herramientas en 8 dominios: usuarios, roles, grupos, aplicaciones, sesiones, logs de auditoría, atributos de usuario y claim mappers. Control de acceso basado en scopes: cada API key otorga solo los permisos que elijas. Un comando para conectar: npx @kotauth/mcp. Sin SDK que aprender, sin HTTP que escribir. Pídele a tu asistente de IA que cree un usuario, establezca atributos personalizados, configure claim mappings o consulte logs de auditoría. Llama a los endpoints correctos automáticamente.',
  },
  {
    icon: Link,
    title: 'Passwordless con Magic-Link',
    description: 'Login sin contraseña basado en email con tokens de un solo uso de 15 minutos. Vinculación de cookie al mismo dispositivo mediante KOTAUTH_AUTH_CONTEXT previene el replay de tokens desde otro navegador. Seguro contra enumeración de usuarios: tiempos de respuesta consistentes sin importar si el email existe. Invariante MFA preservada: el magic link autentica el primer factor, TOTP sigue siendo requerido si está registrado. Los workspaces pueden ser completamente passwordless deshabilitando el login con contraseña por completo.',
  },
  {
    icon: Archive,
    title: 'Backup y Restauración de Tenant',
    description: 'Exporta workspaces completos como snapshots cifrados y portables. Los archivos usan PBKDF2 con 600,000 iteraciones para derivación de claves y AES-256-GCM para cifrado, empaquetados en un formato de envelope autocontenido bkp1. Importación con validación de compatibilidad de versión de esquema para prevenir corrupción de datos. Disponible vía CLI (export-tenant / import-tenant) y endpoints de la API REST de administración.',
  },
  {
    icon: Database,
    title: 'Sesiones Distribuidas con Redis',
    description: 'Sidecar Redis opcional vía KAUTH_REDIS_URL actualiza los almacenes en memoria a almacenamiento de sesiones distribuido y rate limiting. Rate limiting con scripts Lua asegura aplicación consistente en todas las instancias de Kotauth. Semántica fail-closed: la indisponibilidad de Redis rechaza las solicitudes en lugar de omitir los límites. Cliente Lettuce con connection pooling y reconexión automática. Ya no se requieren sticky sessions detrás de un load balancer.',
  },
  {
    icon: UserCheck,
    title: 'Impersonación de Admin',
    description: 'Actúa como cualquier usuario sin conocer su contraseña. Las sesiones de impersonación llevan un claim act de RFC 8693 que identifica al admin, creando un audit trail completo. Modelo de doble sesión: la sesión del admin permanece activa debajo. Revocación en cascada: revocar la sesión del admin también termina la sesión impersonada. Disponible desde la consola de administración con un solo clic.',
  },
  {
    icon: LayoutGrid,
    title: 'Lanzador de Aplicaciones',
    description: 'Cuadrícula de mosaicos por workspace en /t/{slug}/launcher que muestra todas las aplicaciones a las que el usuario tiene derecho de acceso. Modelo de permisos basado en roles con scope de cliente: los usuarios solo ven las apps para las que tienen permiso. Generación automática de mosaicos a partir de aplicaciones OAuth registradas con logo y descripción.',
  },
  {
    icon: Globe,
    title: 'Internacionalización (i18n)',
    description: 'Todas las cadenas de texto de la UI de auth y portal están externalizadas a través de un TranslationPort. Los bundles JSON montados por volumen permiten agregar idiomas sin recompilar. Solo coloca un archivo en KAUTH_I18N_BUNDLE_DIR. Resolución del header Accept-Language con ranking por factor de calidad y fallback elegante a inglés. Cero cadenas de texto en inglés hardcodeadas en las vistas de auth o portal. 174 claves de traducción al español incluidas como implementación de referencia. Emails transaccionales localizados: los 8 tipos de email (verificación, restablecimiento de contraseña, cuenta bloqueada, contraseña cambiada, prueba SMTP, invitación, magic link, OTP) se renderizan en el defaultLocale del tenant con fallback por clave a inglés.',
  },
  {
    icon: ShieldBan,
    title: 'Detección de Contraseñas Filtradas (HIBP)',
    description: 'Las contraseñas se verifican contra la base de datos de Have I Been Pwned usando consultas de rango k-Anonymity durante el registro y cambios de contraseña. Solo los primeros 5 caracteres del hash SHA-1 salen del servidor. BreachedPasswordPort proporciona una interfaz pluggable en la capa de dominio. Combinado con historial de contraseñas, reglas de complejidad y edad máxima, Kotauth aplica higiene de contraseñas en cada punto de contacto.',
  },
  {
    icon: Mail,
    title: 'Passwordless con Email OTP',
    description: 'Autenticación en dos pasos por código de email: ingresa el email, recibe un código de 6 dígitos, inicia sesión. Disponible como primitiva de API de administración (send-otp / verify-otp) y como página de login alojada con flujo en navegador y toggle por tenant. Semántica find-or-create para onboarding passwordless. Defensa de bloqueo cross-challenge con umbral por tenant. Postura de respuesta en tiempo constante previene enumeración por timing. Cadena MFA preservada: usuarios con TOTP registrado siguen siendo desafiados después de la verificación OTP.',
  },
  {
    icon: CircleUserRound,
    title: 'Roles por Defecto del Cliente',
    description: 'Roles por defecto por aplicación asignados automáticamente a usuarios que se auto-registran a través de una aplicación OAuth. Semántica grant-at-registration: los roles se aplican al crear la cuenta, nunca retroactivamente. Protección contra escalamiento de privilegios cross-client evita asociar roles de otra aplicación. Card "Registration Defaults" en la UI de admin con dropdown + tabla de gestión de roles. API REST para gestión programática. Direccionamiento de roles por nombre elimina búsquedas de ID específicas del entorno.',
  },
  {
    icon: Paintbrush,
    title: 'Branding en Emails Transaccionales',
    description: 'Branding de email por tenant: nombre de marca, color, URL del logo, email de soporte y nombre para mostrar del remitente. Las ocho plantillas de email transaccional (verificación, magic link, restablecimiento de contraseña, cuenta bloqueada, invitación, contraseña cambiada, prueba SMTP, OTP) heredan el branding automáticamente. Card de editor de branding en la configuración del workspace. El remitente del envelope permanece bajo control del operador para alineación DKIM/SPF/DMARC.',
  },
];

const rfcBadges = [
  { label: 'RFC 7519', description: 'JSON Web Token (JWT)' },
  { label: 'RFC 7636', description: 'PKCE para OAuth 2.0' },
  { label: 'RFC 7009', description: 'Revocación de Tokens' },
  { label: 'RFC 7662', description: 'Introspección de Tokens' },
  { label: 'RFC 8414', description: 'Metadata del Servidor de Autorización' },
  { label: 'RFC 6238', description: 'Algoritmo TOTP' },
  { label: 'RFC 7807', description: 'Detalles de Problemas para APIs' },
  { label: 'RFC 8707', description: 'Indicadores de Recurso' },
];

const securityPrimitives = [
  { Icon: Lock, label: 'bcrypt', detail: 'Hashing de contraseñas' },
  { Icon: Shield, label: 'AES-256-GCM', detail: 'Claves RSA + secretos en reposo' },
  { Icon: FingerprintPattern, label: 'SHA-256', detail: 'Hashing de API keys' },
  { Icon: FileCode, label: 'RS256', detail: 'Firma JWT por tenant' },
  { Icon: Key, label: 'SRI', detail: 'Integridad de bundles JS' },
  { Icon: RefreshCw, label: 'Rotación de tokens', detail: 'Detección de replay + revocación por familia' },
  { Icon: ShieldAlert, label: 'Bloqueo de cuenta', detail: 'Fuerza bruta + bloqueo TOTP' },
  { Icon: ShieldCheck, label: 'CSP + CSRF', detail: 'Endurecimiento de transporte y solicitudes' },
  { Icon: LogOut, label: 'Contenedor non-root', detail: 'UID 10001, FS de solo lectura' },
];
---

<BaseLayout
  title={i18n.pages.features.title}
  description={i18n.pages.features.description}
  path="/es/features"
>
  <div class="min-h-screen">
    <section class="relative pt-32 pb-16 overflow-hidden">
      <GradientGlow class="top-0 left-1/2 -translate-x-1/2" size={800} color="rgba(0, 119, 168, 0.18)" />
      <div class="section-container relative z-10">
        <div class="max-w-3xl">
          <a
            href={getLocalizedPath('/', 'es')}
            class="inline-flex items-center gap-1.5 text-sm font-mono text-kotauth-text-tertiary hover:text-kotauth-primary transition-colors mb-8 group"
          >
            <ArrowRight class="w-3.5 h-3.5 rotate-180 group-hover:-translate-x-1 transition-transform" />
            Volver al inicio
          </a>
          <span class="eyebrow mb-4 block">Características</span>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-bold text-kotauth-text-primary leading-[1.1] tracking-tight mb-6 font-mono">
            Lo que Kotauth{' '}
            <span class="gradient-text">realmente incluye</span>
          </h1>
          <p class="text-lg text-kotauth-text-secondary leading-relaxed max-w-2xl">
            Cada funcionalidad listada aquí está en producción hoy. Sin etiquetas beta, sin promesas
            de roadmap. Esta es la versión actual v1.19.2, construida con Ktor 3.4, Kotlin 2.3 y Gradle 9.
          </p>
        </div>
      </div>
    </section>

    <AuthShowcase />

    <section class="py-8 pb-24">
      <div class="section-container">
        <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-0">
          {allFeatures.map((feature) => (
            <FeatureCard
              icon={feature.icon}
              title={feature.title}
              description={feature.description}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 relative overflow-hidden">
      <GradientGlow class="bottom-0 right-0 translate-x-1/3" size={600} color="rgba(0, 163, 224, 0.15)" />
      <div class="section-container relative z-10">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Estándares</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Construido sobre estándares abiertos
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Cualquier librería cliente compatible con OIDC funciona con Kotauth sin modificación.
            Estos son los RFCs implementados, no aproximados.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {rfcBadges.map((rfc) => (
            <div class="bg-kotauth-surface-1 border border-kotauth-surface-2 p-4 hover:border-kotauth-primary/30 transition-colors">
              <p class="text-sm font-semibold text-kotauth-primary font-mono mb-1">{rfc.label}</p>
              <p class="text-xs text-kotauth-text-tertiary font-mono leading-relaxed">{rfc.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 bg-kotauth-bg-secondary border-y border-kotauth-surface-2">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Seguridad</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Endurecido antes de tu primer despliegue
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Las decisiones de seguridad se toman a nivel de framework, no se dejan como ejercicios
            de configuración para el operador.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {securityPrimitives.map(({ Icon, label, detail }) => (
            <div class="flex items-start gap-4 p-5 bg-kotauth-surface-1 border border-kotauth-surface-2 hover:border-kotauth-primary/30 transition-colors">
              <div class="w-9 h-9 bg-kotauth-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <Icon class="w-4 h-4 text-kotauth-primary" />
              </div>
              <div>
                <p class="text-sm font-semibold text-kotauth-text-primary font-mono mb-0.5">{label}</p>
                <p class="text-xs text-kotauth-text-tertiary font-mono">{detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="section-container">
        <div class="max-w-2xl">
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-4">
            ¿Listo para desplegar?
          </h2>
          <p class="text-kotauth-text-secondary mb-8">
            Todo lo anterior se incluye en una sola imagen Docker. Sin licencias, sin costo por usuario,
            sin dependencia de SaaS. Míralo funcionando antes de desplegar.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={DEMO_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-kotauth-primary hover:bg-kotauth-primary-light text-white px-6 h-12 font-mono text-sm transition-colors"
            >
              <Play class="w-4 h-4" />
              Probar la Demo
            </a>
            <a
              href={`${GITHUB_URL}#try-it--one-command`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-kotauth-surface-2 text-kotauth-text-primary hover:bg-kotauth-surface-1 hover:border-kotauth-primary/50 px-6 h-12 font-mono text-sm transition-colors"
            >
              Comenzar
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
