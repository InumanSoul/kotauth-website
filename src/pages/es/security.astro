---
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  ArrowRight,
  Lock,
  Shield,
  ShieldCheck,
  Key,
  FileCode,
  RefreshCw,
  ShieldAlert,
  LogOut,
  Clock,
  Eye,
  Server,
  AlertTriangle,
  CheckCircle,
} from '@lucide/astro';
import GradientGlow from '@/components/GradientGlow.astro';
import { t, getLocalizedPath } from '@/i18n';

const i18n = t('es');

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';
const DOCS_URL = 'https://docs.kotauth.com';

const cryptoPrimitives = [
  { Icon: Lock, label: 'bcrypt (cost 12)', detail: 'Hashing de contraseñas: con sal, resistente al tiempo, fuerza bruta inviable' },
  { Icon: Shield, label: 'AES-256-GCM', detail: 'Cifrado en reposo para claves privadas RSA, credenciales SMTP, secretos TOTP y secretos de proveedores sociales' },
  { Icon: Key, label: 'SHA-256', detail: 'Hashing de API keys y tokens: los valores en bruto nunca se almacenan en la base de datos' },
  { Icon: FileCode, label: 'RS256 (RSA-SHA256)', detail: 'Firma de JWT por tenant con pares de claves auto-provisionados, cifrados en reposo' },
  { Icon: RefreshCw, label: 'HMAC-SHA256', detail: 'Firma de cookies de sesión, firma de payloads de webhooks, parámetros de estado OAuth' },
];

const protectionLayers = [
  {
    Icon: ShieldAlert,
    title: 'Bloqueo de cuenta',
    description: 'Umbral configurable de intentos fallidos con duración de bloqueo automático. Los usuarios bloqueados reciben una notificación por email con un enlace de restablecimiento de contraseña. Los administradores pueden desbloquear cuentas manualmente.',
  },
  {
    Icon: Clock,
    title: 'Rate limiting',
    description: '5 intentos de login por minuto, 5 desafíos MFA cada 5 minutos, 3 restablecimientos de contraseña cada 5 minutos, todo por IP por workspace. Aislado por tenant: el tráfico de un workspace nunca afecta a otro.',
  },
  {
    Icon: RefreshCw,
    title: 'Detección de replay de refresh-token',
    description: 'Los refresh tokens rotan en cada uso. Presentar un token previamente rotado se trata como robo de token. Todas las sesiones del usuario son revocadas y se registra un evento de auditoría replay_detected. Los clientes confidenciales deben autenticarse en el grant de refresh.',
  },
  {
    Icon: Eye,
    title: 'Logging de auditoría',
    description: 'Más de 65 tipos de eventos inmutables registrados en la ruta de la solicitud. Ningún flujo de autenticación se completa sin un registro de auditoría correspondiente. Consultable vía API y consola de administración.',
  },
  {
    Icon: LogOut,
    title: 'Replay y bloqueo TOTP',
    description: 'La verificación TOTP rechaza códigos cuyo paso de tiempo ya fue consumido. El replay es estructuralmente imposible. El bloqueo por enrollment se activa después de 5 fallas consecutivas con duración de bloqueo configurable.',
  },
  {
    Icon: Server,
    title: 'Hardening de contenedor',
    description: 'La imagen de runtime se ejecuta como non-root (UID 10001) con no-new-privileges, cap_drop: ALL y filesystem de solo lectura. El modo producción rechaza secretos por defecto, URLs base HTTP o configuración crítica faltante al iniciar.',
  },
];

const transportHardening = [
  'Content-Security-Policy con script-src \'self\' estricto (cero JavaScript inline). Style-src permite \'unsafe-inline\' para tokens de tema inyectados por el servidor; todas las demás directivas bloqueadas a \'self\'',
  'Hashes de integridad SRI en todo el JavaScript empaquetado: previene la manipulación de recursos estáticos',
  'SameSite=Lax en todas las cookies de sesión (admin y portal)',
  'Flag Secure de cookie derivado del esquema de KAUTH_BASE_URL al iniciar',
  'Protección CSRF vía parámetro de estado OAuth + firmas de cookies PKCE',
  'Aplicación de HTTPS en modo producción: HTTP rechazado al iniciar',
  'Prevención de redirección abierta en end-session y post-logout redirect de OIDC: //evil.com, /\\evil.com y URIs de origen ajeno son rechazados',
  'PKCE requerido para todos los clientes OAuth públicos (solo S256)',
  'Headers de Forwarded habilitados bajo opt-in vía KAUTH_TRUSTED_PROXY: previene bypass de rate-limit mediante spoofing de headers en despliegues expuestos directamente',
  'Normalización de errores de login + ecualización de tiempos: todas las ramas de rechazo comparten la misma latencia de respuesta mediante verificación bcrypt de relleno',
  'La introspección de JWT valida el issuer: tokens generados para el tenant A no pueden ser introspeccionados contra el tenant B',
  'Entradas de TenantTheme validadas del lado del servidor: patrones estrictos para colores hex, familias de fuentes, border-radius, locale (BCP-47) y esquemas de URL de logo',
  'Puerta de verificación de email en social-link: el auto-enlace por email rechaza direcciones de proveedor no verificadas',
];

const passwordPolicies = [
  'Longitud mínima configurable (4–128 caracteres)',
  'Requiere mayúsculas, minúsculas, números y/o caracteres especiales',
  'Historial de contraseñas: previene la reutilización de las últimas N contraseñas (0–24)',
  'Edad máxima de contraseña: fuerza expiración después de N días (0–365)',
  'Lista negra de contraseñas: rechaza contraseñas conocidas como comprometidas',
  'Factor de costo bcrypt 12: las contraseñas en bruto nunca se almacenan ni registran en logs',
];

const secretsPolicy = [
  { what: 'Contraseñas de usuario', how: 'Hash bcrypt (cost 12). La contraseña en bruto se descarta después de la verificación.' },
  { what: 'Secretos de cliente', how: 'Hash bcrypt. El valor en bruto se muestra una vez al generarse, nunca es recuperable.' },
  { what: 'API keys', how: 'Hash SHA-256. Formato: kauth_{slug}_{random}. El prefijo se almacena para visualización.' },
  { what: 'Refresh tokens', how: 'Hash SHA-256. Rotan en cada uso. El token antiguo revoca la sesión.' },
  { what: 'Claves privadas RSA', how: 'Cifradas en reposo con AES-256-GCM. Las claves en texto plano se migran automáticamente en el primer inicio.' },
  { what: 'Credenciales SMTP', how: 'Cifradas en reposo con AES-256-GCM. Clave derivada de KAUTH_SECRET_KEY.' },
  { what: 'Secretos de proveedores sociales', how: 'Cifrados en reposo con AES-256-GCM. Misma derivación de clave.' },
  { what: 'Secretos TOTP de MFA', how: 'Cifrados en reposo con AES-256-GCM. Codificados en Base32 para URI de QR.' },
  { what: 'Códigos de recuperación', how: 'Hash bcrypt. Uso único. 8 códigos generados por enrollment de MFA.' },
];
---

<BaseLayout
  title={i18n.pages.security.title}
  description={i18n.pages.security.description}
  path="/es/security"
>
  <div class="min-h-screen">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <GradientGlow class="top-0 left-1/2 -translate-x-1/2" size={800} color="rgba(0, 119, 168, 0.18)" />
      <div class="section-container relative z-10">
        <div class="max-w-3xl">
          <a
            href={getLocalizedPath('/', 'es')}
            class="inline-flex items-center gap-1.5 text-sm font-mono text-kotauth-text-tertiary hover:text-kotauth-primary transition-colors mb-8 group"
          >
            <ArrowRight class="w-3.5 h-3.5 rotate-180 group-hover:-translate-x-1 transition-transform" />
            Volver al inicio
          </a>
          <span class="eyebrow mb-4 block">Seguridad</span>
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-bold text-kotauth-text-primary leading-[1.1] tracking-tight mb-6 font-mono">
            Seguridad <span class="gradient-text">por defecto</span>
          </h1>
          <p class="text-lg text-kotauth-text-secondary leading-relaxed max-w-2xl">
            Las decisiones de seguridad se toman a nivel de framework, no se dejan como ejercicios de configuración para el operador. Todo lo listado aquí se incluye en cada despliegue de Kotauth sin configuración adicional.
          </p>
        </div>
      </div>
    </section>

    <!-- Crypto primitives -->
    <section class="py-24 bg-kotauth-bg-secondary border-y border-kotauth-surface-2">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Criptografía</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Primitivas criptográficas
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Algoritmos estándar de la industria sin criptografía personalizada. Cada secreto sigue el mismo principio: almacenar el mínimo necesario, en la forma más fuerte disponible.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cryptoPrimitives.map(({ Icon, label, detail }) => (
            <div class="flex items-start gap-4 p-5 bg-kotauth-surface-1 border border-kotauth-surface-2 hover:border-kotauth-primary/30 transition-colors">
              <div class="w-9 h-9 bg-kotauth-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <Icon class="w-4 h-4 text-kotauth-primary" />
              </div>
              <div>
                <p class="text-sm font-semibold text-kotauth-text-primary font-mono mb-0.5">{label}</p>
                <p class="text-xs text-kotauth-text-tertiary font-mono leading-relaxed">{detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Protection layers -->
    <section class="py-24">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Defensa en profundidad</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Capas de protección
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Múltiples defensas independientes. Una falla en una capa no compromete el sistema.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-0">
          {protectionLayers.map(({ Icon, title, description }) => (
            <div class="p-8 bg-kotauth-surface-1 border border-kotauth-surface-2 hover:border-kotauth-primary/30 transition-colors">
              <div class="w-12 h-12 bg-kotauth-primary/10 flex items-center justify-center mb-5">
                <Icon class="w-5 h-5 text-kotauth-primary" />
              </div>
              <h3 class="text-base font-semibold text-kotauth-text-primary font-mono mb-2">{title}</h3>
              <p class="text-sm text-kotauth-text-tertiary leading-relaxed">{description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Secrets policy -->
    <section class="py-24 bg-kotauth-bg-secondary border-y border-kotauth-surface-2">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Protección de datos</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Cómo se almacenan los secretos
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Una brecha en la base de datos no debería revelar nada utilizable. Cada tipo de credencial tiene su propia estrategia de almacenamiento.
          </p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm font-mono border-collapse">
            <thead>
              <tr class="border-b border-kotauth-surface-2">
                <th class="text-left py-3 pr-6 text-xs text-kotauth-text-muted uppercase tracking-widest font-normal">Secreto</th>
                <th class="text-left py-3 text-xs text-kotauth-text-muted uppercase tracking-widest font-normal">Método de almacenamiento</th>
              </tr>
            </thead>
            <tbody>
              {secretsPolicy.map((row) => (
                <tr class="border-b border-kotauth-surface-1 hover:bg-kotauth-surface-1/40 transition-colors">
                  <td class="py-3 pr-6 text-kotauth-text-primary text-xs whitespace-nowrap">{row.what}</td>
                  <td class="py-3 text-kotauth-text-tertiary text-xs leading-relaxed">{row.how}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Transport hardening -->
    <section class="py-24">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Transporte</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Hardening de transporte y solicitudes
          </h2>
        </div>

        <div class="max-w-3xl space-y-3">
          {transportHardening.map((item) => (
            <div class="flex items-start gap-3 p-4 bg-kotauth-surface-1 border border-kotauth-surface-2">
              <CheckCircle class="w-4 h-4 text-kotauth-success flex-shrink-0 mt-0.5" />
              <span class="text-sm text-kotauth-text-tertiary font-mono leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Password policy -->
    <section class="py-24 bg-kotauth-bg-secondary border-y border-kotauth-surface-2">
      <div class="section-container">
        <div class="mb-12">
          <span class="eyebrow mb-4 block">Política de contraseñas</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-3">
            Configurable por workspace
          </h2>
          <p class="text-kotauth-text-secondary max-w-xl">
            Cada workspace define su propia política de contraseñas. Todas las configuraciones son ajustables desde la consola de administración.
          </p>
        </div>

        <div class="max-w-3xl space-y-3">
          {passwordPolicies.map((item) => (
            <div class="flex items-start gap-3 p-4 bg-kotauth-surface-1 border border-kotauth-surface-2">
              <Shield class="w-4 h-4 text-kotauth-primary flex-shrink-0 mt-0.5" />
              <span class="text-sm text-kotauth-text-tertiary font-mono leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Reporting -->
    <section class="py-24">
      <div class="section-container">
        <div class="max-w-2xl">
          <span class="eyebrow mb-4 block">Reportar</span>
          <h2 class="text-2xl sm:text-3xl font-semibold text-kotauth-text-primary font-mono mb-4">
            Reportar una vulnerabilidad
          </h2>
          <p class="text-kotauth-text-secondary mb-8">
            Si descubres una vulnerabilidad de seguridad, repórtala de forma privada a través de GitHub Security Advisories. No abras un issue público. Tomamos todos los reportes en serio y responderemos con prontitud.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={`${GITHUB_URL}/security/advisories/new`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-kotauth-primary hover:bg-kotauth-primary-light text-white px-6 h-12 font-mono text-sm transition-colors"
            >
              <AlertTriangle class="w-4 h-4" />
              Reportar en Privado
            </a>
            <a
              href={`${DOCS_URL}/deployment/production/`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-kotauth-surface-2 text-kotauth-text-primary hover:bg-kotauth-surface-1 hover:border-kotauth-primary/50 px-6 h-12 font-mono text-sm transition-colors"
            >
              Checklist de Producción
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
