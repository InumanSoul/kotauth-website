---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactSection from '@/sections/ContactSection.astro';
import { t } from '@/i18n';

const i18n = t('es');
---

<BaseLayout
  title={i18n.pages.contact.title}
  description={i18n.pages.contact.description}
  path="/es/contact"
>
  <div class="pt-[72px]">
    <ContactSection />
  </div>
</BaseLayout>
