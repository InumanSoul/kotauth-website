---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, formatDate, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';

type Tag = 'Added' | 'Improved' | 'Changed' | 'Fixed' | 'Security';
type ChangeItem = { tag: Tag; text: string };
type Release = { version: string; date: string; current?: boolean; items: ChangeItem[] };

const releases: Release[] = [
  {
    version: '1.19.2',
    date: 'June 22, 2026',
    current: true,
    items: [
      { tag: 'Changed', text: 'Dos archivos compose en la raíz (docker-compose.yml + docker-compose.prod.yml) reemplazan a los seis que vivían en docker/' },
      { tag: 'Changed', text: 'El overlay de DB externa se reemplaza por DB_URL en .env; el overlay de demo se reemplaza por KAUTH_DEMO_MODE=true en .env' },
      { tag: 'Improved', text: 'Toda la guía de despliegue se movió a la documentación; se eliminaron los comentarios del Dockerfile, el Caddyfile y los archivos compose' },
    ],
  },
  {
    version: '1.19.1',
    date: 'June 22, 2026',
    items: [
      { tag: 'Added', text: 'Inyección de secretos basada en archivos (convención *_FILE) para KAUTH_SECRET_KEY, DB_PASSWORD, KAUTH_REDIS_PASSWORD, KAUTH_BOOTSTRAP_ADMIN_PASSWORD y KAUTH_BOOTSTRAP_API_KEYS' },
      { tag: 'Added', text: 'Bloqueo de dependencias de Gradle: gradle.lockfile fija el grafo de dependencias resuelto y CI lo verifica en cada PR' },
      { tag: 'Added', text: 'Dependabot habilitado para alertas semanales sobre dependencias de Gradle, GitHub Actions e imágenes base de Docker' },
    ],
  },
  {
    version: '1.19.0',
    date: 'June 19, 2026',
    items: [
      { tag: 'Security', text: 'Cadena HMAC sobre el registro de auditoría: cada fila lleva prev_hash y row_hash mediante HMAC-SHA256 con clave KAUTH_SECRET_KEY; cualquier manipulación o reordenamiento rompe la cadena' },
      { tag: 'Added', text: 'El nuevo comando CLI verify-audit-chain detecta filas de auditoría manipuladas o reordenadas' },
      { tag: 'Fixed', text: 'Los detalles del registro de auditoría ahora usan kotlinx.serialization, corrigiendo la corrupción silenciosa de JSON por cadenas concatenadas a mano' },
      { tag: 'Fixed', text: 'Introspección de tokens multi-audiencia: AccessTokenClaims.aud se amplió para admitir el formato de array' },
    ],
  },
  {
    version: '1.18.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Added', text: 'Resource Indicators de RFC 8707 para el grant client_credentials: tokens M2M dirigidos por audiencia con aud vinculado al recurso solicitado' },
      { tag: 'Added', text: 'Registro de APIs (admin: /settings/apis): CRUD con alcance de workspace para identificadores de audiencia' },
      { tag: 'Added', text: 'Pantalla "Authorized APIs" por cliente con autorización mediante casillas y metadatos de Discovery que anuncian resource_indicators_supported: true' },
      { tag: 'Security', text: 'Los recursos desconocidos o no autorizados devuelven RFC 8707 invalid_target 400 en lugar de un token silenciosamente amplio' },
    ],
  },
  {
    version: '1.17.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Added', text: 'Los 8 tipos de email transaccional ahora están localizados: verificación, magic link, restablecimiento de contraseña, cuenta bloqueada, invitación, contraseña cambiada, prueba de SMTP y OTP' },
      { tag: 'Added', text: 'Las plantillas de email se renderizan en el defaultLocale del workspace con fallback al inglés por clave' },
      { tag: 'Security', text: 'Proxy de confianza opcional (KAUTH_TRUSTED_PROXY): evita eludir el rate limiting mediante spoofing de cabeceras' },
      { tag: 'Security', text: 'Validación del issuer de JWT: los tokens emitidos por un tenant son rechazados por otro' },
      { tag: 'Security', text: 'Prevención de open redirect: el redirect_uri posterior al login se valida contra los valores registrados' },
      { tag: 'Security', text: 'La comparación del code verifier de PKCE S256 usa igualdad de tiempo constante' },
      { tag: 'Security', text: 'La cabecera Server se suprime de las respuestas HTTP' },
      { tag: 'Security', text: 'La normalización de errores de login con igualación de tiempos previene la enumeración de usuarios' },
    ],
  },
  {
    version: '1.16.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Security', text: 'El contenedor se ejecuta como non-root (UID 10001) con no-new-privileges, cap_drop: ALL y sistema de archivos de solo lectura' },
      { tag: 'Security', text: 'Protección contra replay de TOTP: cada código es de un solo uso por enrolamiento; bloqueo tras un número configurable de intentos fallidos' },
      { tag: 'Fixed', text: 'La validación de variables CSS del tema evita la inyección de valores arbitrarios a través de la configuración del workspace' },
      { tag: 'Improved', text: 'Tiempos de error de login igualados en las rutas de verificación de contraseña y de TOTP' },
    ],
  },
  {
    version: '1.15.0',
    date: 'June 15, 2026',
    items: [
      { tag: 'Changed', text: 'AdminService se dividió en AuthManagementService, UserAdminService y WorkspaceAdminService' },
      { tag: 'Changed', text: 'UserSelfServiceService se dividió en UserProfileService y UserSecurityService' },
      { tag: 'Improved', text: 'Se endureció el ratchet de Detekt: reglas de complejidad y acoplamiento aplicadas en CI' },
    ],
  },
  {
    version: '1.14.1',
    date: 'June 12, 2026',
    items: [
      { tag: 'Security', text: 'BREAKING: Se eliminó la credencial de admin por defecto. Se genera una contraseña aleatoria en el primer arranque y se registra una sola vez en stdout.' },
    ],
  },
  {
    version: '1.14.0',
    date: 'June 11, 2026',
    items: [
      { tag: 'Security', text: 'BREAKING: El endpoint de refresh token ahora requiere autenticación de cliente (client_id + client_secret para clientes confidenciales)' },
      { tag: 'Security', text: 'BREAKING: Los endpoints de introspección y revocación requieren autenticación de cliente según RFC 7662 / RFC 7009' },
      { tag: 'Added', text: 'Detección de replay de refresh token con revocación completa de la familia de sesiones al reutilizarse' },
      { tag: 'Added', text: 'Bloqueo de cuenta con umbral configurable e interfaz de desbloqueo para administradores' },
    ],
  },
  {
    version: '1.13.0',
    date: 'May 26, 2026',
    items: [
      { tag: 'Added', text: 'Login con Email OTP alojado: autenticación passwordless de dos pasos en el navegador (ingresa el email, recibe un código de 6 dígitos, inicia sesión)' },
      { tag: 'Added', text: 'Conmutador por tenant para Email OTP desde la configuración del workspace' },
      { tag: 'Added', text: 'Primitivas de API de administración send-otp / verify-otp para onboarding passwordless programático' },
      { tag: 'Security', text: 'Defensa de bloqueo entre desafíos: umbral de intentos de OTP por tenant con respuesta de tiempo constante' },
    ],
  },
  {
    version: '1.12.1',
    date: 'May 26, 2026',
    items: [
      { tag: 'Fixed', text: 'Desajuste del prefijo de las API keys bootstrap: kauth_{slug}_ ahora se aplica de forma consistente en la generación y la validación' },
      { tag: 'Fixed', text: 'Validación de redirect URI más estricta: se requiere coincidencia exacta y se rechazan las variantes con barra final' },
      { tag: 'Improved', text: 'Especificación OpenAPI actualizada con los endpoints de envío/verificación de OTP y la documentación de filtros del registro de auditoría' },
      { tag: 'Improved', text: 'Los grupos de filtros del registro de auditoría se muestran en la interfaz de administración para una navegación más clara por categoría de evento' },
    ],
  },
  {
    version: '1.12.0',
    date: 'May 25, 2026',
    items: [
      { tag: 'Added', text: 'Roles por defecto del cliente: roles por aplicación asignados automáticamente a los usuarios que se autorregistran a través de una aplicación OAuth' },
      { tag: 'Added', text: 'Tarjeta de "Registration Defaults" en la consola de administración con menú desplegable y tabla de gestión de roles' },
      { tag: 'Added', text: 'Protección contra escalada de privilegios entre clientes: los roles de otras aplicaciones no pueden asignarse como predeterminados' },
    ],
  },
  {
    version: '1.11.0',
    date: 'May 23, 2026',
    items: [
      { tag: 'Added', text: 'Branding de emails transaccionales: nombre de marca, color, URL del logo, email de soporte y nombre de remitente por tenant' },
      { tag: 'Added', text: 'Las 8 plantillas de email transaccional heredan automáticamente el branding del workspace' },
      { tag: 'Added', text: 'Tarjeta de editor de branding en la configuración del workspace con vista previa en vivo' },
    ],
  },
  {
    version: '1.10.0',
    date: 'May 12, 2026',
    items: [
      { tag: 'Added', text: 'Impersonación de admin: actúa como cualquier usuario sin conocer su contraseña, con el claim act de RFC 8693 en el token de sesión' },
      { tag: 'Added', text: 'Modelo de doble sesión: la sesión del admin permanece activa por debajo de la sesión impersonada' },
      { tag: 'Security', text: 'Revocación en cascada: revocar la sesión del admin también termina la sesión impersonada' },
    ],
  },
  {
    version: '1.9.0',
    date: 'May 8, 2026',
    items: [
      { tag: 'Added', text: 'Servidor MCP nativo de IA (@kotauth/mcp): 33 herramientas en 8 dominios expuestas vía Model Context Protocol' },
      { tag: 'Added', text: 'Control de acceso basado en alcances en cada herramienta MCP: la API key otorga solo los permisos que elijas' },
      { tag: 'Added', text: 'Conexión con un comando: npx @kotauth/mcp' },
    ],
  },
];

const tagColors: Record<string, string> = {
  Added: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  Improved: 'bg-kotauth-primary/5 text-kotauth-primary border-kotauth-primary/20',
  Changed: 'bg-slate-100 text-slate-500 border-slate-200',
  Fixed: 'bg-amber-50 text-amber-700 border-amber-200',
  Security: 'bg-red-50 text-red-700 border-red-200',
};

const tagLabels: Record<string, string> = {
  Added: 'Añadido',
  Improved: 'Mejorado',
  Changed: 'Cambiado',
  Fixed: 'Corregido',
  Security: 'Seguridad',
};
---

<BaseLayout
  title={i18n.pages.changelog.title}
  description={i18n.pages.changelog.description}
  path="/changelog"
>
  <!-- Header -->
  <section class="relative px-7 pt-32 pb-14 text-center overflow-hidden">
    <div
      class="absolute -top-[120px] left-1/2 -translate-x-1/2 w-[900px] h-[420px] max-w-full pointer-events-none"
      style="background:radial-gradient(ellipse at center,rgba(0,119,168,.1),transparent 70%);"
    ></div>
    <div class="relative max-w-[680px] mx-auto">
      <span class="eyebrow">Historial</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-[54px] text-kotauth-text-primary leading-[1.06] tracking-[-0.03em] mt-3.5 mb-[18px]">
        Historial de versiones
      </h1>
      <p class="text-lg sm:text-[18.5px] text-kotauth-text-secondary leading-[1.6] max-w-[620px] mx-auto">
        Cada versión, con qué cambió y por qué. Kotauth sigue el versionado semántico.
      </p>
    </div>
  </section>

  <!-- Tag legend -->
  <section class="max-w-[880px] mx-auto px-7 pb-9">
    <div class="flex flex-wrap gap-3.5 justify-center">
      {Object.entries(tagColors).map(([tag, cls]) => (
        <span class={`inline-flex items-center font-mono text-[11px] font-semibold border px-[9px] py-[3px] ${cls}`}>{tagLabels[tag]}</span>
      ))}
    </div>
  </section>

  <!-- Releases -->
  <section class="max-w-[880px] mx-auto px-7 pb-24">
    {releases.map((rel) => (
      <div class="grid grid-cols-1 sm:grid-cols-[170px_1fr] gap-5 sm:gap-8 py-8 border-t border-kotauth-surface-2">
        <div>
          <a
            href={`${GITHUB_URL}/releases/tag/v${rel.version}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block font-mono text-[15px] font-semibold text-kotauth-text-primary bg-white border border-kotauth-surface-2 px-[11px] py-[5px] mb-2 hover:text-kotauth-primary hover:border-kotauth-primary/40 transition-colors"
          >
            v{rel.version}
          </a>
          <div class="text-[13px] text-kotauth-text-muted">{formatDate(rel.date, locale)}</div>
          {rel.current && (
            <div class="inline-flex items-center gap-1.5 mt-2 text-[11.5px] font-semibold text-emerald-600">
              <span class="w-[7px] h-[7px] rounded-full bg-emerald-500"></span>Versión actual
            </div>
          )}
        </div>
        <div class="flex flex-col gap-[11px]">
          {rel.items.map((ch) => (
            <div class="flex gap-3 items-start">
              <span class={`flex-shrink-0 font-mono text-[10.5px] font-semibold border px-2 py-[3px] w-[72px] text-center ${tagColors[ch.tag]}`}>
                {tagLabels[ch.tag]}
              </span>
              <p class="text-[14.5px] text-kotauth-text-secondary leading-[1.55]">{ch.text}</p>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-10 pt-8 border-t border-kotauth-surface-2">
      <a
        href={`${GITHUB_URL}/releases`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-kotauth-primary hover:text-kotauth-primary-light transition-colors font-medium"
      >
        Ver todas las versiones en GitHub &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
