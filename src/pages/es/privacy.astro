---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);
---

<BaseLayout
  title={i18n.pages.privacy.title}
  description={i18n.pages.privacy.description}
  path="/privacy"
>
  <section class="bg-white">
    <header class="max-w-[760px] mx-auto px-7 pt-32 pb-9">
      <span class="eyebrow mb-3 block">Legal</span>
      <h1 class="font-heading font-bold text-[38px] sm:text-[46px] leading-[1.08] tracking-[-0.03em] text-kotauth-text-primary mb-3">
        Política de Privacidad
      </h1>
      <p class="font-mono text-[13px] text-kotauth-text-muted">Última actualización: junio 2026</p>
    </header>

    <article class="max-w-[760px] mx-auto px-7 pb-[100px]">
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Esta política explica qué información recopila el sitio web kotauth.com y cómo se utiliza. Abarca únicamente el sitio web de marketing. Cuando alojas Kotauth por tu cuenta, los datos que procesa tu instancia permanecen en tu infraestructura y se rigen por tus propias políticas, no por esta.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Información que recopilamos</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Mantenemos la recopilación al mínimo. El sitio web no requiere una cuenta para navegar. Si envías el formulario de contacto, recibimos el nombre, la dirección de correo electrónico y el mensaje que proporcionas para poder responderte.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Analítica</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Usamos una analítica respetuosa con la privacidad y sin cookies para comprender el tráfico de forma agregada, como qué páginas son más populares. Esta analítica no instala cookies de seguimiento, no construye perfiles entre sitios y no identifica a visitantes individuales.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Cookies</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        El sitio web de marketing no utiliza cookies publicitarias ni de seguimiento. Cualquier almacenamiento se limita a lo estrictamente necesario para el funcionamiento del sitio, como recordar tu preferencia de idioma.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Cómo usamos la información</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Usamos la información que envías únicamente para responder a tu consulta y para mejorar el sitio web. No vendemos tus datos personales ni los compartimos con terceros para sus propios fines de marketing.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Despliegues auto-alojados</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Kotauth es software que ejecutas tú mismo. No tenemos acceso a los usuarios, tokens ni registros de auditoría que procesa tu instancia. Tú eres el responsable del tratamiento de todo lo que hay dentro de tu despliegue.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Tus derechos</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Puedes solicitar el acceso, la corrección o la eliminación de cualquier dato personal que nos hayas enviado a través del formulario de contacto. Escríbenos y atenderemos las solicitudes razonables.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Contacto</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        ¿Tienes preguntas sobre esta política? Contáctanos a través de la <a href="/contact" class="text-kotauth-primary font-semibold hover:text-kotauth-primary-light transition-colors">página de contacto</a>.
      </p>
    </article>
  </section>
</BaseLayout>
