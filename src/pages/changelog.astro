---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, formatDate, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';

type Tag = 'Added' | 'Improved' | 'Changed' | 'Fixed' | 'Security';
type ChangeItem = { tag: Tag; text: string };
type Release = { version: string; date: string; current?: boolean; items: ChangeItem[] };

const releases: Release[] = [
  {
    version: '1.19.2',
    date: 'June 22, 2026',
    current: true,
    items: [
      { tag: 'Changed', text: 'Two root compose files (docker-compose.yml + docker-compose.prod.yml) replace six that lived under docker/' },
      { tag: 'Changed', text: 'External-DB overlay replaced by DB_URL in .env; demo overlay replaced by KAUTH_DEMO_MODE=true in .env' },
      { tag: 'Improved', text: 'All deployment guidance moved to docs; comments stripped from Dockerfile, Caddyfile, and compose files' },
    ],
  },
  {
    version: '1.19.1',
    date: 'June 22, 2026',
    items: [
      { tag: 'Added', text: 'File-based secret injection (*_FILE convention) for KAUTH_SECRET_KEY, DB_PASSWORD, KAUTH_REDIS_PASSWORD, KAUTH_BOOTSTRAP_ADMIN_PASSWORD, and KAUTH_BOOTSTRAP_API_KEYS' },
      { tag: 'Added', text: 'Gradle dependency locking: gradle.lockfile pins the resolved dependency graph, CI verifies on every PR' },
      { tag: 'Added', text: 'Dependabot enabled for weekly alerts on Gradle deps, GitHub Actions, and Docker base images' },
    ],
  },
  {
    version: '1.19.0',
    date: 'June 19, 2026',
    items: [
      { tag: 'Security', text: 'HMAC chain over audit log: each row carries prev_hash and row_hash via HMAC-SHA256 keyed by KAUTH_SECRET_KEY; tampering or reordering breaks the chain' },
      { tag: 'Added', text: 'New verify-audit-chain CLI command detects tampered or reordered audit rows' },
      { tag: 'Fixed', text: 'Audit log details now use kotlinx.serialization, fixing silent JSON corruption from hand-concatenated strings' },
      { tag: 'Fixed', text: 'Multi-audience token introspection: AccessTokenClaims.aud widened to support array format' },
    ],
  },
  {
    version: '1.18.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Added', text: 'RFC 8707 Resource Indicators for client_credentials grant: audience-targeted M2M tokens with aud bound to the requested resource' },
      { tag: 'Added', text: 'APIs registry (admin: /settings/apis): workspace-scoped CRUD for audience identifiers' },
      { tag: 'Added', text: 'Per-client "Authorized APIs" screen with checkbox authorization and Discovery metadata advertising resource_indicators_supported: true' },
      { tag: 'Security', text: 'Unknown or unauthorized resources return RFC 8707 invalid_target 400 instead of a silently-broad token' },
    ],
  },
  {
    version: '1.17.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Added', text: 'All 8 transactional email types localized: verification, magic link, password reset, account locked, invite, password changed, SMTP test, and OTP' },
      { tag: 'Added', text: 'Email templates render in the workspace defaultLocale with per-key English fallback' },
      { tag: 'Security', text: 'Trusted proxy opt-in (KAUTH_TRUSTED_PROXY): prevents rate-limit bypass via header spoofing' },
      { tag: 'Security', text: 'JWT issuer enforcement: tokens issued by one tenant are rejected by another' },
      { tag: 'Security', text: 'Open redirect prevention: post-login redirect_uri validated against registered values' },
      { tag: 'Security', text: 'PKCE S256 code verifier comparison uses constant-time equality' },
      { tag: 'Security', text: 'Server response header suppressed from HTTP responses' },
      { tag: 'Security', text: 'Login error normalization with timing equalization prevents user enumeration' },
    ],
  },
  {
    version: '1.16.0',
    date: 'June 17, 2026',
    items: [
      { tag: 'Security', text: 'Container ships non-root (UID 10001) with no-new-privileges, cap_drop: ALL, and read-only filesystem' },
      { tag: 'Security', text: 'TOTP replay protection: each code is single-use per enrollment; lockout after configurable failed attempts' },
      { tag: 'Fixed', text: 'Theme CSS variable validation prevents injection of arbitrary values via workspace settings' },
      { tag: 'Improved', text: 'Login error timing equalized across password and TOTP verification paths' },
    ],
  },
  {
    version: '1.15.0',
    date: 'June 15, 2026',
    items: [
      { tag: 'Changed', text: 'AdminService split into AuthManagementService, UserAdminService, and WorkspaceAdminService' },
      { tag: 'Changed', text: 'UserSelfServiceService split into UserProfileService and UserSecurityService' },
      { tag: 'Improved', text: 'Detekt ratchet tightened: complexity and coupling rules enforced in CI' },
    ],
  },
  {
    version: '1.14.1',
    date: 'June 12, 2026',
    items: [
      { tag: 'Security', text: 'BREAKING: Default admin credential removed. A random password is generated on first boot and logged once to stdout.' },
    ],
  },
  {
    version: '1.14.0',
    date: 'June 11, 2026',
    items: [
      { tag: 'Security', text: 'BREAKING: Refresh token endpoint now requires client authentication (client_id + client_secret for confidential clients)' },
      { tag: 'Security', text: 'BREAKING: Introspection and revocation endpoints require client authentication per RFC 7662 / RFC 7009' },
      { tag: 'Added', text: 'Refresh-token replay detection with full session-family revocation on reuse' },
      { tag: 'Added', text: 'Account lockout with configurable threshold and admin unlock UI' },
    ],
  },
  {
    version: '1.13.0',
    date: 'May 26, 2026',
    items: [
      { tag: 'Added', text: 'Hosted Email OTP login: browser-driven two-step passwordless authentication (enter email, receive 6-digit code, sign in)' },
      { tag: 'Added', text: 'Per-tenant toggle for Email OTP via workspace settings' },
      { tag: 'Added', text: 'send-otp / verify-otp admin API primitives for programmatic passwordless onboarding' },
      { tag: 'Security', text: 'Cross-challenge lockout defense: per-tenant OTP attempt threshold with constant-time response posture' },
    ],
  },
  {
    version: '1.12.1',
    date: 'May 26, 2026',
    items: [
      { tag: 'Fixed', text: 'Bootstrap API key prefix mismatch: kauth_{slug}_ now consistently applied at generation and validation' },
      { tag: 'Fixed', text: 'Redirect-URI validation tightened: exact match required, trailing-slash variants rejected' },
      { tag: 'Improved', text: 'OpenAPI spec updated with OTP send/verify endpoints and audit log filter documentation' },
      { tag: 'Improved', text: 'Audit log filter groups surfaced in admin UI for cleaner event category browsing' },
    ],
  },
  {
    version: '1.12.0',
    date: 'May 25, 2026',
    items: [
      { tag: 'Added', text: 'Client default roles: per-application roles automatically assigned to users who self-register through an OAuth application' },
      { tag: 'Added', text: 'Registration Defaults card in admin console with dropdown and role management table' },
      { tag: 'Added', text: 'Cross-client privilege-escalation guard: roles from other applications cannot be assigned as defaults' },
    ],
  },
  {
    version: '1.11.0',
    date: 'May 23, 2026',
    items: [
      { tag: 'Added', text: 'Transactional email branding: per-tenant brand name, color, logo URL, support email, and from display name' },
      { tag: 'Added', text: 'All 8 transactional email templates inherit workspace branding automatically' },
      { tag: 'Added', text: 'Branding editor card in workspace settings with live preview' },
    ],
  },
  {
    version: '1.10.0',
    date: 'May 12, 2026',
    items: [
      { tag: 'Added', text: 'Admin impersonation: act as any user without knowing their password, with RFC 8693 act claim in the session token' },
      { tag: 'Added', text: 'Dual-session model: admin session stays active underneath the impersonated session' },
      { tag: 'Security', text: 'Cascade revocation: revoking the admin session also terminates the impersonated session' },
    ],
  },
  {
    version: '1.9.0',
    date: 'May 8, 2026',
    items: [
      { tag: 'Added', text: 'AI-native MCP server (@kotauth/mcp): 33 tools across 8 domains exposed via Model Context Protocol' },
      { tag: 'Added', text: 'Scope-based access control on every MCP tool: API key grants only the permissions you choose' },
      { tag: 'Added', text: 'One-command connect: npx @kotauth/mcp' },
    ],
  },
];

const tagColors: Record<string, string> = {
  Added: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  Improved: 'bg-kotauth-primary/5 text-kotauth-primary border-kotauth-primary/20',
  Changed: 'bg-slate-100 text-slate-500 border-slate-200',
  Fixed: 'bg-amber-50 text-amber-700 border-amber-200',
  Security: 'bg-red-50 text-red-700 border-red-200',
};
---

<BaseLayout
  title={i18n.pages.changelog.title}
  description={i18n.pages.changelog.description}
  path="/changelog"
>
  <!-- Header -->
  <section class="relative px-7 pt-32 pb-14 text-center overflow-hidden">
    <div
      class="absolute -top-[120px] left-1/2 -translate-x-1/2 w-[900px] h-[420px] max-w-full pointer-events-none"
      style="background:radial-gradient(ellipse at center,rgba(0,119,168,.1),transparent 70%);"
    ></div>
    <div class="relative max-w-[680px] mx-auto">
      <span class="eyebrow">Changelog</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-[54px] text-kotauth-text-primary leading-[1.06] tracking-[-0.03em] mt-3.5 mb-[18px]">
        Release history
      </h1>
      <p class="text-lg sm:text-[18.5px] text-kotauth-text-secondary leading-[1.6] max-w-[620px] mx-auto">
        Every release, with what changed and why. Kotauth follows semantic versioning.
      </p>
    </div>
  </section>

  <!-- Tag legend -->
  <section class="max-w-[880px] mx-auto px-7 pb-9">
    <div class="flex flex-wrap gap-3.5 justify-center">
      {Object.entries(tagColors).map(([tag, cls]) => (
        <span class={`inline-flex items-center font-mono text-[11px] font-semibold border px-[9px] py-[3px] ${cls}`}>{tag}</span>
      ))}
    </div>
  </section>

  <!-- Releases -->
  <section class="max-w-[880px] mx-auto px-7 pb-24">
    {releases.map((rel) => (
      <div class="grid grid-cols-1 sm:grid-cols-[170px_1fr] gap-5 sm:gap-8 py-8 border-t border-kotauth-surface-2">
        <div>
          <a
            href={`${GITHUB_URL}/releases/tag/v${rel.version}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block font-mono text-[15px] font-semibold text-kotauth-text-primary bg-white border border-kotauth-surface-2 px-[11px] py-[5px] mb-2 hover:text-kotauth-primary hover:border-kotauth-primary/40 transition-colors"
          >
            v{rel.version}
          </a>
          <div class="text-[13px] text-kotauth-text-muted">{formatDate(rel.date, locale)}</div>
          {rel.current && (
            <div class="inline-flex items-center gap-1.5 mt-2 text-[11.5px] font-semibold text-emerald-600">
              <span class="w-[7px] h-[7px] rounded-full bg-emerald-500"></span>Current release
            </div>
          )}
        </div>
        <div class="flex flex-col gap-[11px]">
          {rel.items.map((ch) => (
            <div class="flex gap-3 items-start">
              <span class={`flex-shrink-0 font-mono text-[10.5px] font-semibold border px-2 py-[3px] w-[72px] text-center ${tagColors[ch.tag]}`}>
                {ch.tag}
              </span>
              <p class="text-[14.5px] text-kotauth-text-secondary leading-[1.55]">{ch.text}</p>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-10 pt-8 border-t border-kotauth-surface-2">
      <a
        href={`${GITHUB_URL}/releases`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-kotauth-primary hover:text-kotauth-primary-light transition-colors font-medium"
      >
        View all releases on GitHub &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
