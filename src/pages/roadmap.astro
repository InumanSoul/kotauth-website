---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);

const GITHUB_URL = 'https://github.com/inumansoul/kotauth';

const columns = [
  {
    status: 'Shipped',
    description: 'Live today on v1.19.2.',
    legendDot: 'bg-[#1F9D55]',
    badgeWrap: 'bg-[#EAF7EF] border border-[#CDEBD9]',
    badgeDot: 'bg-[#1F9D55]',
    badgeText: 'text-[#1F8A4C]',
    cardClass: 'bg-white border border-kotauth-surface-2 shadow-[0_1px_3px_rgba(15,22,41,0.04)]',
    titleClass: 'text-kotauth-text-primary',
    bodyClass: 'text-kotauth-text-secondary',
    items: [
      { title: 'OAuth 2.0 & OIDC core', body: 'Full provider with PKCE, token rotation and discovery.' },
      { title: 'Multi-tenant workspaces', body: 'Isolated directories, keys and policies per tenant.' },
      { title: 'AI-native MCP server', body: '33 scoped tools across 8 domains.' },
      { title: 'White-label auth screens', body: 'Server-rendered, themed per workspace.' },
      { title: 'Magic-link & Email OTP', body: 'Passwordless flows that stay MFA-aware.' },
      { title: 'Encrypted backup & restore', body: 'Portable tenant snapshots via CLI or API.' },
    ],
  },
  {
    status: 'In progress',
    description: 'Actively in development for upcoming releases.',
    legendDot: 'bg-kotauth-primary',
    badgeWrap: 'bg-[#EAF6FB] border border-[#CDE8F5]',
    badgeDot: 'bg-kotauth-primary',
    badgeText: 'text-kotauth-primary',
    cardClass: 'bg-white border border-kotauth-surface-2 border-l-[3px] border-l-kotauth-primary shadow-[0_1px_3px_rgba(15,22,41,0.04)]',
    titleClass: 'text-kotauth-text-primary',
    bodyClass: 'text-kotauth-text-secondary',
    items: [
      { title: 'Enterprise SSO', body: 'LDAP and SAML federation for upstream identity providers.' },
      { title: 'Passkeys & WebAuthn', body: 'Phishing-resistant sign-in alongside existing methods.' },
      { title: 'Webhook event streaming', body: 'Subscribe downstream systems to audit and lifecycle events.' },
      { title: 'Admin impersonation', body: 'Scoped, fully audited support sessions.' },
    ],
  },
  {
    status: 'Planned',
    description: 'Committed, scoped, and queued.',
    legendDot: 'bg-[#D9890E]',
    badgeWrap: 'bg-[#FBF1E2] border border-[#F0DCBC]',
    badgeDot: 'bg-[#D9890E]',
    badgeText: 'text-[#B5730C]',
    cardClass: 'bg-white border border-kotauth-surface-2 shadow-[0_1px_3px_rgba(15,22,41,0.04)]',
    titleClass: 'text-kotauth-text-primary',
    bodyClass: 'text-kotauth-text-secondary',
    items: [
      { title: 'SCIM provisioning', body: 'Automated user lifecycle sync with external directories.' },
      { title: 'Fine-grained authorization', body: 'Relationship-based access control for complex permissions.' },
      { title: 'Self-service org management', body: 'Let end users create and administer their own organizations.' },
      { title: 'Audit log export', body: 'Stream to SIEM targets and object storage on a schedule.' },
    ],
  },
  {
    status: 'Exploring',
    description: 'Researching. Tell us if you need these.',
    legendDot: 'bg-[#A6AEBA]',
    badgeWrap: 'bg-[#F2F3F5] border border-kotauth-surface-2',
    badgeDot: 'bg-[#A6AEBA]',
    badgeText: 'text-[#7A8694]',
    cardClass: 'bg-[#FBFBFC] border border-dashed border-[#D8DCE3]',
    titleClass: 'text-kotauth-text-secondary',
    bodyClass: 'text-kotauth-text-muted',
    items: [
      { title: 'Device authorization flow', body: 'Sign in on input-constrained devices like TVs and CLIs.' },
      { title: 'Step-up authentication', body: 'Demand stronger factors for sensitive operations.' },
      { title: 'Policy-as-code', body: 'Version-controlled security policies applied at deploy time.' },
      { title: 'Org-level billing hooks', body: 'Usage signals for teams building products on top of Kotauth.' },
    ],
  },
];
---

<BaseLayout
  title={i18n.pages.roadmap.title}
  description={i18n.pages.roadmap.description}
  path="/roadmap"
>
  <!-- Page header -->
  <section class="relative px-7 pt-32 pb-14 text-center overflow-hidden">
    <div
      class="absolute -top-[120px] left-1/2 -translate-x-1/2 w-[900px] h-[420px] pointer-events-none"
      style="background:radial-gradient(ellipse at center,rgba(0,119,168,.1),transparent 70%);"
    ></div>
    <div class="relative max-w-[720px] mx-auto">
      <span class="eyebrow">Roadmap</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl lg:text-[54px] leading-[1.06] tracking-[-0.03em] text-kotauth-text-primary mt-[14px] mb-[18px]">
        What we are building next
      </h1>
      <p class="text-lg leading-[1.6] text-kotauth-text-secondary font-medium">
        Kotauth is open source and built in the open. This is where things stand and where they are headed. Priorities shift with community input.
      </p>
    </div>
  </section>

  <!-- Status legend -->
  <section class="max-w-[920px] mx-auto px-7 pb-10">
    <div class="flex flex-wrap justify-center gap-x-[22px] gap-y-3 text-[13px] font-semibold text-kotauth-text-secondary">
      {columns.map((col) => (
        <span class="inline-flex items-center gap-[7px]">
          <span class={`w-[9px] h-[9px] inline-block ${col.legendDot}`}></span>
          {col.status}
        </span>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-[920px] mx-auto px-7 pb-20">
    {columns.map((col, i) => (
      <div
        class={`grid grid-cols-1 md:grid-cols-[200px_1fr] gap-8 py-[34px] border-t border-kotauth-surface-2 ${i === columns.length - 1 ? 'border-b' : ''}`}
      >
        <div>
          <div class={`inline-flex items-center gap-2 px-[11px] py-[5px] mb-2 ${col.badgeWrap}`}>
            <span class={`w-2 h-2 inline-block ${col.badgeDot}`}></span>
            <span class={`text-[12.5px] font-bold ${col.badgeText}`}>{col.status}</span>
          </div>
          <p class="text-[13px] text-kotauth-text-muted leading-[1.5]">{col.description}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-[14px]">
          {col.items.map((item) => (
            <div class={`px-5 py-[18px] ${col.cardClass}`}>
              <h3 class={`font-heading text-[15px] font-bold mb-1 ${col.titleClass}`}>{item.title}</h3>
              <p class={`text-[13px] leading-[1.5] ${col.bodyClass}`}>{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- Shape it -->
  <section class="max-w-[920px] mx-auto px-7 pb-28">
    <div class="bg-kotauth-bg-secondary border border-kotauth-surface-2 px-10 py-11 text-center">
      <h2 class="font-heading font-bold text-[28px] tracking-[-0.02em] text-kotauth-text-primary mb-[10px]">Have a say in what ships next</h2>
      <p class="text-base leading-[1.6] text-kotauth-text-secondary font-medium max-w-[480px] mx-auto mb-6">
        Roadmap priorities are shaped in public. Open a discussion, file a request, or upvote what matters to you.
      </p>
      <div class="flex flex-wrap justify-center gap-[13px]">
        <a
          href={`${GITHUB_URL}/discussions`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-kotauth-primary hover:bg-kotauth-primary-light text-white px-[22px] h-12 text-[14.5px] font-semibold transition-colors"
        >
          Join the discussion
        </a>
        <a
          href={`${GITHUB_URL}/issues/new`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white border border-kotauth-surface-2 text-kotauth-text-primary hover:border-kotauth-primary/40 px-[22px] h-12 text-[14.5px] font-semibold transition-colors"
        >
          Request a feature
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
