---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t, type Locale, defaultLocale } from '@/i18n';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const i18n = t(locale);
---

<BaseLayout
  title={i18n.pages.privacy.title}
  description={i18n.pages.privacy.description}
  path="/privacy"
>
  <section class="bg-white">
    <header class="max-w-[760px] mx-auto px-7 pt-32 pb-9">
      <span class="eyebrow mb-3 block">Legal</span>
      <h1 class="font-heading font-bold text-[38px] sm:text-[46px] leading-[1.08] tracking-[-0.03em] text-kotauth-text-primary mb-3">
        Privacy Policy
      </h1>
      <p class="font-mono text-[13px] text-kotauth-text-muted">Last updated June 2026</p>
    </header>

    <article class="max-w-[760px] mx-auto px-7 pb-[100px]">
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        This policy explains what information the kotauth.com website collects and how it is used. It covers the marketing website only. When you self-host Kotauth, the data your instance processes stays on your infrastructure and is governed by your own policies, not this one.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Information we collect</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        We keep collection to a minimum. The website does not require an account to browse. If you submit the contact form, we receive the name, email address, and message you provide so we can reply.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Analytics</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        We use privacy-friendly, cookieless analytics to understand aggregate traffic, such as which pages are popular. These analytics do not set tracking cookies, do not build cross-site profiles, and do not identify individual visitors.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Cookies</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        The marketing website does not use advertising or tracking cookies. Any storage is limited to what is strictly necessary for the site to function, such as remembering your language preference.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">How we use information</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        We use the information you submit solely to respond to your inquiry and to improve the website. We do not sell your personal data, and we do not share it with third parties for their own marketing.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Self-hosted deployments</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Kotauth is software you run yourself. We have no access to the users, tokens, or audit logs your instance processes. You are the data controller for everything inside your deployment.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Your rights</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        You can request access to, correction of, or deletion of any personal data you have sent us through the contact form. Reach out and we will action reasonable requests.
      </p>

      <h2 class="font-heading text-[22px] font-bold tracking-[-0.01em] text-kotauth-text-primary mt-[38px] mb-3">Contact</h2>
      <p class="text-[16px] leading-[1.75] text-kotauth-text-secondary">
        Questions about this policy? Reach us through the <a href="/contact" class="text-kotauth-primary font-semibold hover:text-kotauth-primary-light transition-colors">contact page</a>.
      </p>
    </article>
  </section>
</BaseLayout>
