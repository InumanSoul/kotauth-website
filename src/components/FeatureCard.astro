---
import type { LucideIcon } from 'lucide-react';

interface Props {
  icon: LucideIcon;
  title: string;
  description: string;
}

const { icon: Icon, title, description } = Astro.props;
---

<div class="group p-8 bg-kotauth-surface-1 border border-kotauth-surface-2 transition-all duration-300 h-full min-h-64">
  <div class="mb-5">
    <div class="w-12 h-12 bg-kotauth-primary/10 flex items-center justify-center transition-transform duration-200 group-hover:scale-110">
      <Icon className="w-6 h-6 text-kotauth-primary" />
    </div>
  </div>
  <h3 class="text-lg font-semibold text-kotauth-text-primary mb-3 font-mono">
    {title}
  </h3>
  <p class="text-kotauth-text-secondary leading-relaxed">
    {description}
  </p>
</div>
