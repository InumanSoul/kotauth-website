---
import { CircleCheck, Circle } from '@lucide/astro';

interface Props {
  phase: {
    number: number;
    title: string;
    tagline: string;
    items: string[];
  };
  shipped: boolean;
}

const { phase, shipped } = Astro.props;
---

<div
  data-reveal
  class={`relative flex gap-6 pb-12 last:pb-0 ${!shipped ? 'opacity-80' : ''}`}
>
  <div class="flex flex-col items-center flex-shrink-0">
    <div
      class={`w-10 h-10 flex items-center justify-center border-2 z-10 flex-shrink-0 ${
        shipped
          ? 'bg-kotauth-primary/15 border-kotauth-primary text-kotauth-primary'
          : 'bg-kotauth-surface-1 border-kotauth-surface-3 text-kotauth-text-muted'
      }`}
    >
      {shipped ? (
        <CircleCheck class="w-5 h-5" />
      ) : (
        <Circle class="w-5 h-5" />
      )}
    </div>
    <div class="w-px flex-1 mt-2 bg-kotauth-surface-2" />
  </div>

  <div class="flex-1 min-w-0 pt-1.5">
    <div class="flex items-center gap-3 mb-1 flex-wrap">
      <span class="text-xs font-mono text-kotauth-text-muted">Phase {phase.number}</span>
      {shipped ? (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono bg-kotauth-success/10 text-kotauth-success border border-kotauth-success/20">
          ✓ Shipped
        </span>
      ) : (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono bg-kotauth-surface-2 text-kotauth-text-muted border border-kotauth-surface-3">
          Planned
        </span>
      )}
    </div>
    <h3 class="text-xl font-semibold text-kotauth-text-primary font-mono mb-1">
      {phase.title}
    </h3>
    <p class="text-sm text-kotauth-text-secondary mb-5 italic">{phase.tagline}</p>

    <ul class="space-y-2.5">
      {phase.items.map((item) => (
        <li class="flex items-start gap-2.5">
          <span
            class={`mt-1.5 w-1.5 h-1.5 flex-shrink-0 ${
              shipped ? 'bg-kotauth-primary' : 'bg-kotauth-surface-3'
            }`}
          />
          <span class="text-sm text-kotauth-text-tertiary leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
