---
interface Props {
  className?: string;
  size?: number;
  color?: string;
}

const { className = '', size = 600, color = 'rgba(0, 119, 168, 0.22)' } = Astro.props;
---

<div
  class={`absolute pointer-events-none glow-drift ${className}`}
  style={`width:${size}px;height:${size}px;background:radial-gradient(circle,${color} 0%,transparent 70%);filter:blur(40px);`}
/>
